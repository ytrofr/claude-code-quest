<svg class="qd-icon qd-icon-sealed" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
  <!-- Brass key crossed with lock plate — sealed. -->
  <g stroke="#4a2e1a" stroke-width="1.1" stroke-linejoin="round">
    <!-- Key bow (ring) -->
    <circle cx="6" cy="12" r="3.2" fill="none" stroke-width="1.5"/>
    <!-- Key shaft -->
    <line x1="9" y1="12" x2="20" y2="12" stroke-width="1.5"/>
    <!-- Key teeth -->
    <line x1="17" y1="12" x2="17" y2="15" stroke-width="1.5"/>
    <line x1="14" y1="12" x2="14" y2="14.5" stroke-width="1.5"/>
    <!-- Lock plate (small, behind) -->
    <rect x="18" y="9" width="4" height="6" fill="#c89030" stroke-width="0.8"/>
  </g>
</svg>
