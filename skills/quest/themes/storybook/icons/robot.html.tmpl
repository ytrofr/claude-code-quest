<svg class="qd-icon qd-icon-robot" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
  <!-- Clockwork eye — storybook theme. Brass gear with watching pupil. -->
  <g stroke="#4a2e1a" stroke-width="1" stroke-linejoin="round">
    <!-- Outer gear teeth -->
    <g fill="#c89030">
      <rect x="11" y="1" width="2" height="3"/>
      <rect x="11" y="20" width="2" height="3"/>
      <rect x="1" y="11" width="3" height="2"/>
      <rect x="20" y="11" width="3" height="2"/>
      <rect x="3.7" y="3.7" width="2" height="3" transform="rotate(-45 4.7 5.2)"/>
      <rect x="18.3" y="3.7" width="2" height="3" transform="rotate(45 19.3 5.2)"/>
      <rect x="3.7" y="17.3" width="2" height="3" transform="rotate(45 4.7 18.8)"/>
      <rect x="18.3" y="17.3" width="2" height="3" transform="rotate(-45 19.3 18.8)"/>
    </g>
    <!-- Gear body -->
    <circle cx="12" cy="12" r="7" fill="#c89030"/>
    <!-- Eye socket -->
    <circle cx="12" cy="12" r="4.5" fill="#fbf3df"/>
    <!-- Iris -->
    <circle cx="12" cy="12" r="2.5" fill="#7a5a3a" stroke="none"/>
    <!-- Pupil -->
    <circle cx="12" cy="12" r="1.2" fill="#4a2e1a" stroke="none"/>
    <circle cx="12.5" cy="11.4" r="0.4" fill="#fbf3df" stroke="none"/>
  </g>
</svg>
