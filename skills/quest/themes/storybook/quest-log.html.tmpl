<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{name}} — Chapter Index</title>
<link href="https://fonts.googleapis.com/css2?family=Eczar:wght@500;700&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; }
  body { margin: 0; min-height: 100vh; font-family: 'Quicksand', system-ui, sans-serif; background: #c8a672; padding: 18px; color: #4a2e1a; }
  .frame { max-width: 1280px; margin: 0 auto; background: #fbf3df; border: 6px double #8a6f4a; border-radius: 12px; overflow: hidden; box-shadow: 0 12px 36px rgba(60,40,20,0.4); position: relative; }
  .frame::before { content: ''; position: absolute; inset: 10px; border: 1px solid rgba(138,111,74,0.4); pointer-events: none; border-radius: 6px; z-index: 1; }
  .head { padding: 16px 28px; background: linear-gradient(180deg, #fbf3df 0%, #f3e6c4 100%); border-bottom: 2px dashed #8a6f4a; display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; position: relative; z-index: 2; }
  .title-row { display: flex; align-items: center; gap: 14px; }
  .crest { width: 56px; height: 56px; }
  h1 { margin: 0; font-family: 'Eczar', serif; font-weight: 700; font-size: 30.8px; color: #4a2e1a; line-height: 1.1; }
  .sub { font-family: 'Eczar', serif; font-style: italic; font-size: 15.4px; color: #7a5a3a; margin-top: 2px; }
  .nav { display: flex; gap: 6px; margin: 0 8px; align-items: center; }
  .nav a { padding: 8px 14px; background: #fbf3df; border: 2.5px solid #4a2e1a; font-family: 'Eczar', serif; font-weight: 700; font-size: 13.2px; color: #4a2e1a; text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase; }
  .nav a.active { background: #4a2e1a; color: #fbf3df; }
  .qd-back-link { padding: 4px 10px; background: #c89030; border: 2px solid #4a2e1a; color: #4a2e1a; text-decoration: none; font-family: 'Eczar', serif; font-weight: 700; font-size: 12.1px; letter-spacing: 1.5px; text-transform: uppercase; }
  .qd-back-link:hover { background: #d8a040; }
  .xp-block { display: flex; align-items: center; gap: 12px; }
  .xp-bar { width: 200px; height: 16px; background: #ede0c0; border: 2px solid #4a2e1a; border-radius: 10px; overflow: hidden; position: relative; }
  .xp-fill { height: 100%; background: linear-gradient(180deg, #f0c050 0%, #c89030 100%); }
  .xp-text { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12.1px; color: #4a2e1a; }
  .body { padding: 32px 56px 40px; position: relative; z-index: 2; }
  .toc-h { text-align: center; margin: 0 0 8px; font-family: 'Eczar', serif; font-weight: 700; font-size: 39.6px; color: #4a2e1a; letter-spacing: 1px; }
  .toc-sub { text-align: center; font-family: 'Eczar', serif; font-style: italic; font-size: 17.6px; color: #7a5a3a; margin: 0 0 8px; }
  .ornament { text-align: center; color: #c89030; font-size: 24.2px; letter-spacing: 14px; margin: 8px 0 28px; }
  .toc { max-width: 880px; margin: 0 auto; }
  .row { display: grid; grid-template-columns: 64px 80px 1fr auto; gap: 18px; align-items: center; padding: 18px 12px; border-bottom: 1px dotted #8a6f4a; cursor: pointer; text-decoration: none; color: inherit; }
  .row:hover { background: rgba(138,111,74,0.08); }
  .row:first-child { border-top: 1px dotted #8a6f4a; }
  .row .roman { font-family: 'Eczar', serif; font-weight: 700; font-size: 30.8px; color: #7a5a3a; text-align: center; line-height: 1; }
  .row.current .roman { color: #c44a2a; }
  .row.locked .roman { color: #b8a890; }
  .row .pic { width: 80px; height: 80px; background: #fbf3df; border: 2px solid #4a2e1a; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .row.locked .pic { opacity: 0.55; border-style: dashed; }
  .row .info { flex: 1; min-width: 0; }
  .row .ch-name { margin: 0 0 4px; font-family: 'Eczar', serif; font-weight: 700; font-size: 24.2px; color: #4a2e1a; line-height: 1.15; }
  .row.current .ch-name { color: #c44a2a; }
  .row.locked .ch-name { color: #8a7860; font-style: italic; }
  .row .ch-desc { font-family: 'Eczar', serif; font-style: italic; font-size: 15.4px; color: #7a5a3a; margin: 0; line-height: 1.4; }
  .row .ch-prog { display: flex; align-items: center; gap: 8px; margin-top: 8px; max-width: 280px; }
  .row .ch-prog .bar { flex: 1; height: 8px; background: #ede0c0; border: 2px solid #4a2e1a; border-radius: 4px; overflow: hidden; }
  .row .ch-prog .fill { height: 100%; background: linear-gradient(180deg, #e07050 0%, #c44a2a 100%); }
  .row .ch-prog .pct { font-family: 'Eczar', serif; font-weight: 700; font-size: 15.4px; color: #c44a2a; }
  .row .right-tag { font-family: 'Eczar', serif; font-weight: 700; font-size: 15.4px; padding: 6px 14px; border: 2px solid; border-radius: 4px; white-space: nowrap; }
  .row.done .right-tag { color: #5e9a4a; border-color: #5e9a4a; background: rgba(94,154,74,0.06); }
  .row.current .right-tag { color: #c44a2a; border-color: #c44a2a; background: rgba(196,74,42,0.06); }
  .row.locked .right-tag { color: #8a7860; border-color: #8a7860; border-style: dashed; }
  .stamp { display: inline-block; padding: 3px 10px; font-family: 'Eczar', serif; font-style: italic; font-size: 12.1px; letter-spacing: 1.5px; text-transform: uppercase; border-radius: 3px; }
  .row.done .stamp { color: #5e9a4a; background: rgba(94,154,74,0.1); border: 1px solid #5e9a4a; }
  .row.current .stamp { color: #c44a2a; background: rgba(196,74,42,0.1); border: 1px solid #c44a2a; }
  .row.locked .stamp { color: #8a7860; background: rgba(138,120,96,0.08); border: 1px dashed #8a7860; }
  .meta-row { display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap; align-items: center; font-family: 'Quicksand'; font-size: 13.2px; color: #7a5a3a; font-weight: 600; }
  .row .ch-prog { display: none; }
  .row.current .ch-prog { display: flex; }
</style>
</head>
<body>
<div class="frame">
  <header class="head">
    <div class="title-row">
      <svg class="crest" viewBox="0 0 56 56">
        <path d="M 28 4 L 50 14 V 30 Q 50 46 28 52 Q 6 46 6 30 V 14 Z" fill="#fbf3df" stroke="#4a2e1a" stroke-width="2.5"/>
        <path d="M 28 12 L 42 18 V 30 Q 42 40 28 44 Q 14 40 14 30 V 18 Z" fill="#c89030" stroke="#4a2e1a" stroke-width="1.5"/>
        <text x="28" y="32" text-anchor="middle" dominant-baseline="central" font-family="Eczar" font-weight="700" font-size="16" fill="#fbf3df">{{level_roman}}</text>
      </svg>
      <div>
        <h1>The Tale of {{name}}</h1>
        <div class="sub">an index of {{counts.total}} chapters</div>
      </div>
    </div>
    <nav class="nav">
      {{> _back-link}}
      <a href="route.html">MAP</a>
      <a href="quest-log.html" class="active">CHAPTERS</a>
    </nav>
    <div class="xp-block">
      <div class="xp-bar"><div class="xp-fill" style="width:{{xp_pct}}%"></div><div class="xp-text">{{xp.current}} / {{xp.max}}</div></div>
    </div>
  </header>

  <div class="body">
    <h2 class="toc-h">Of Endeavours</h2>
    <p class="toc-sub">a complete index, with notations on those completed, present, and yet to come</p>
    <div class="ornament">❦ ⁂ ❦</div>

    <div class="toc">
      {{#each quests}}
      <a class="row {{q.status_class}}" href="plan-card.html?ch={{q.n}}">
        <div class="roman">{{q.roman}}.</div>
        <div class="pic">
          <svg viewBox="0 0 80 80" preserveAspectRatio="xMidYMid meet">
            <rect width="80" height="80" fill="#fbf3df"/>
            <g transform="translate(40,55) scale(0.7)">{{{q.landmark_svg}}}</g>
          </svg>
        </div>
        <div class="info">
          <h3 class="ch-name">{{q.name}}</h3>
          <p class="ch-desc">{{q.desc}}</p>
          <div class="ch-prog">
            <div class="bar"><div class="fill" style="width:{{q.progress_pct}}%"></div></div>
            <span class="pct">{{q.progress_pct}}%</span>
          </div>
          <div class="meta-row">
            <span class="stamp">{{q.status_class}}</span>
            <span>+{{q.xp_reward}} leagues</span>
          </div>
        </div>
        <div class="right-tag">+{{q.xp_reward}}</div>
      </a>
      {{/each}}
    </div>

    <div class="ornament">❦ ⁂ ❦</div>
  </div>
</div>
</body>
</html>
