<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{name}} — Chapter {{active.n}}: {{active.name}}</title>
<link href="https://fonts.googleapis.com/css2?family=Eczar:wght@500;700&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; }
  body { margin: 0; min-height: 100vh; font-family: 'Quicksand', system-ui, sans-serif; background: #c8a672; padding: 18px; color: #4a2e1a; }
  .frame { max-width: 1280px; margin: 0 auto; background: #fbf3df; border: 6px double #8a6f4a; border-radius: 12px; overflow: hidden; box-shadow: 0 12px 36px rgba(60,40,20,0.4); position: relative; }
  .frame::before { content: ''; position: absolute; inset: 10px; border: 1px solid rgba(138,111,74,0.4); pointer-events: none; border-radius: 6px; z-index: 1; }
  .head { padding: 16px 28px; background: linear-gradient(180deg, #fbf3df 0%, #f3e6c4 100%); border-bottom: 2px dashed #8a6f4a; display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; position: relative; z-index: 2; }
  .title-row { display: flex; align-items: center; gap: 14px; }
  .crest { width: 56px; height: 56px; }
  h1 { margin: 0; font-family: 'Eczar', serif; font-weight: 700; font-size: 28.6px; color: #4a2e1a; line-height: 1.1; }
  .sub { font-family: 'Eczar', serif; font-style: italic; font-size: 15.4px; color: #7a5a3a; margin-top: 2px; }
  .nav { display: flex; gap: 6px; margin: 0 8px; }
  .nav a { padding: 8px 14px; background: #fbf3df; border: 2.5px solid #4a2e1a; font-family: 'Eczar', serif; font-weight: 700; font-size: 13.2px; color: #4a2e1a; text-decoration: none; letter-spacing: 1.5px; text-transform: uppercase; }
  .crumbs { padding: 12px 28px; background: #f3e6c4; border-bottom: 2px dashed #8a6f4a; display: flex; align-items: center; gap: 8px; font-family: 'Eczar', serif; font-style: italic; font-size: 15.4px; color: #7a5a3a; position: relative; z-index: 2; }
  .crumbs a { color: #4a2e1a; text-decoration: none; padding: 4px 10px; border: 2px solid #4a2e1a; background: #fbf3df; font-weight: 700; font-style: normal; }
  .crumbs .here { padding: 4px 10px; background: #c44a2a; color: #fbf3df; border: 2px solid #4a2e1a; font-weight: 700; font-style: normal; }
  .spread { display: grid; grid-template-columns: 1fr 1fr; gap: 0; position: relative; z-index: 2; min-height: 70vh; }
  .spread::before { content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 2px; background: linear-gradient(180deg, transparent 0%, rgba(138,111,74,0.4) 20%, rgba(138,111,74,0.4) 80%, transparent 100%); transform: translateX(-1px); pointer-events: none; }
  .left-page { padding: 28px 32px 28px 56px; }
  .right-page { padding: 28px 56px 28px 32px; }
  .illus-frame { background: #f9eecf; border: 2px solid #8a6f4a; padding: 16px; }
  .illus-frame svg { width: 100%; height: auto; display: block; }
  .illus-cap { font-family: 'Eczar', serif; font-style: italic; font-size: 15.4px; color: #7a5a3a; text-align: center; margin-top: 14px; padding: 0 30px; line-height: 1.5; }
  .illus-stats { margin-top: 22px; padding: 14px 18px; background: rgba(196,74,42,0.06); border: 2px solid #c44a2a; }
  .illus-stats .h { font-family: 'Eczar', serif; font-weight: 700; font-size: 12.1px; letter-spacing: 3px; color: #c44a2a; text-transform: uppercase; margin-bottom: 10px; }
  .illus-stats .row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px dotted rgba(138,111,74,0.3); font-family: 'Eczar', serif; }
  .illus-stats .row:last-child { border-bottom: none; }
  .illus-stats .lbl { font-style: italic; color: #7a5a3a; font-size: 14.3px; }
  .illus-stats .val { font-weight: 700; color: #4a2e1a; font-size: 15.4px; }
  .chapter-mark { font-family: 'Eczar', serif; font-style: italic; font-size: 14.3px; letter-spacing: 4px; color: #7a5a3a; text-transform: uppercase; text-align: center; margin-bottom: 4px; }
  h2 { margin: 0 0 4px; text-align: center; font-family: 'Eczar', serif; font-weight: 700; font-size: 39.6px; color: #4a2e1a; line-height: 1.1; }
  .epigraph { text-align: center; font-family: 'Eczar', serif; font-style: italic; font-size: 15.4px; color: #7a5a3a; margin-bottom: 8px; }
  .ornament { text-align: center; color: #c89030; margin: 12px 0 22px; font-size: 19.8px; letter-spacing: 14px; }
  .narrative { font-family: 'Eczar', serif; font-size: 17.6px; line-height: 1.65; color: #2a1f15; }
  .narrative .drop-cap { float: left; font-family: 'Eczar', serif; font-weight: 700; font-size: 70.4px; line-height: 0.85; color: #c89030; padding: 6px 10px 0 0; }
  .narrative p { margin: 0 0 14px; }
  .pull { font-family: 'Eczar', serif; font-style: italic; font-size: 19.8px; line-height: 1.55; padding: 14px 0 14px 18px; border-left: 3px solid #c44a2a; margin: 16px 0; color: #4a2e1a; }
  .deeds { margin-top: 22px; padding: 18px 22px; background: rgba(196,74,42,0.05); border: 2px solid #c44a2a; }
  .deeds .h { font-family: 'Eczar', serif; font-weight: 700; font-size: 13.2px; letter-spacing: 3px; color: #c44a2a; text-transform: uppercase; margin-bottom: 12px; text-align: center; }
  .deed { padding: 8px 0; border-bottom: 1px dotted rgba(138,111,74,0.3); font-family: 'Eczar', serif; font-size: 16.5px; }
  .margin { margin-top: 22px; padding-top: 14px; border-top: 1px dotted #8a6f4a; font-family: 'Eczar', serif; font-style: italic; font-size: 14.3px; color: #7a5a3a; line-height: 1.6; }
  .margin code { font-family: ui-monospace, monospace; font-style: normal; background: #f3e6c4; padding: 2px 6px; border: 1px solid #c89030; font-size: 13.2px; }
  .actions { display: flex; gap: 10px; margin-top: 22px; flex-wrap: wrap; justify-content: center; }
  .btn { padding: 10px 18px; border: 2.5px solid #4a2e1a; font-family: 'Eczar', serif; font-weight: 700; font-size: 15.4px; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
  .btn.primary { background: #c44a2a; color: #fbf3df; }
  .btn.ghost { background: #fbf3df; color: #4a2e1a; }
  .twinkle { animation: tw 2s ease-in-out infinite; transform-origin: center; transform-box: fill-box; }
  @keyframes tw { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.08); opacity: 0.85; } }

  /* shared partial CSS — storybook theme */
  .qd-back-link { display: inline-block; padding: 4px 10px; background: #fbf3df; border: 2px solid #4a2e1a; color: #4a2e1a; text-decoration: none; font-family: 'Eczar', serif; font-weight: 700; font-style: normal; font-size: 13.2px; letter-spacing: 1px; text-transform: uppercase; }
  .qd-back-link:hover { background: #f3e6c4; }
  .qd-pills { display: flex; flex-wrap: wrap; gap: 6px; margin: 10px 0 4px; font-family: 'Eczar', serif; }
  .qd-pill { padding: 3px 10px; font-size: 12.1px; font-weight: 700; color: #4a2e1a; background: #fbf3df; border: 1.5px solid #4a2e1a; line-height: 1.3; white-space: nowrap; max-width: 100%; overflow: hidden; text-overflow: ellipsis; letter-spacing: 0.5px; }
  .qd-pill-branch { background: #ede0c0; }
  .qd-pill-kpi { background: #f0c050; }
  .qd-pill-tags { background: #f3e6c4; font-style: italic; font-weight: 600; }
  .qd-why { margin: 12px 0 0; padding: 10px 14px; background: rgba(196,74,42,0.07); border-left: 3px solid #c44a2a; font-family: 'Eczar', serif; font-size: 15.4px; font-style: italic; color: #4a2e1a; line-height: 1.5; }
  .qd-why-mark { color: #c44a2a; font-style: normal; margin-right: 6px; }
  .qd-tasks { margin-top: 18px; padding: 16px 20px; background: rgba(196,74,42,0.05); border: 2px solid #c44a2a; }
  .qd-tasks-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px; }
  .qd-tasks-title { margin: 0; font-family: 'Eczar', serif; font-weight: 700; font-size: 13.2px; letter-spacing: 3px; color: #c44a2a; text-transform: uppercase; }
  .qd-tasks-count { font-family: 'Eczar', serif; font-weight: 700; font-size: 14.3px; color: #c44a2a; }
  .qd-deeds-toggle { margin-left: auto; padding: 4px 12px; background: #fbf3df; border: 2px solid #4a2e1a; font-family: 'Eczar', serif; font-weight: 700; font-size: 11.5px; color: #4a2e1a; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; letter-spacing: 1.5px; text-transform: uppercase; }
  .qd-deeds-toggle:hover { background: #f3e6c4; }
  .qd-deeds-toggle:focus-visible { outline: 2px solid #c44a2a; outline-offset: 2px; }
  .qd-deeds-toggle.on { background: #c44a2a; color: #fbf3df; border-color: #4a2e1a; }
  .qd-toggle-mark { display: inline-block; width: 14px; height: 14px; border: 2px solid currentColor; text-align: center; font-weight: 800; line-height: 10px; font-size: 11px; }
  .qd-deeds-toggle.on .qd-toggle-mark::before { content: '✓'; }
  body.hide-done-deeds .qd-task.qd-task-done { display: none; }
  /* Storyline link styles + plan-file chips */
  .qd-storyline-link { color: #c44a2a; font-weight: 700; text-decoration: none; border-bottom: 1px dotted #c44a2a; }
  .qd-storyline-link:hover { background: #f3e6c4; border-bottom-style: solid; }
  .qd-storyline-arrow { color: #c44a2a; font-weight: 800; }
  .qd-plan-chip { display: inline-block; margin: 2px 4px 2px 0; padding: 2px 8px; background: #fbf3df; border: 1px solid #8a6f4a; font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #4a2e1a; }
  .qd-tasks-list { list-style: none; padding: 0; margin: 0; }
  .qd-task { padding: 6px 0; font-family: 'Eczar', serif; font-size: 15.4px; border-bottom: 1px dotted rgba(138,111,74,0.3); }
  .qd-task:last-child { border-bottom: none; }
  .qd-task > span { display: inline-flex; align-items: flex-start; gap: 10px; }
  .qd-task-summary { display: flex; align-items: center; gap: 10px; cursor: pointer; list-style: none; padding: 2px 0; }
  .qd-task-summary::-webkit-details-marker { display: none; }
  .qd-task-mark { display: inline-block; width: 18px; height: 18px; border: 1.5px solid #4a2e1a; text-align: center; font-weight: 700; line-height: 15px; font-size: 13.2px; flex-shrink: 0; background: #fbf3df; }
  .qd-task-done .qd-task-mark { background: #c44a2a; color: #fbf3df; border-color: #4a2e1a; }
  .qd-task-done .qd-task-title { color: #7a5a3a; text-decoration: line-through; font-style: italic; }
  .qd-task-todo .qd-task-mark { color: transparent; }
  .qd-task-title { color: #2a1f15; flex: 1; }
  .qd-task-arrow { color: #c44a2a; font-size: 13.2px; transition: transform 0.2s ease; opacity: 0.7; }
  .qd-task-details[open] .qd-task-arrow { transform: rotate(90deg); opacity: 1; }
  .qd-task-brief { margin: 6px 0 6px 28px; padding: 10px 12px; background: #fbf3df; border: 1px solid #c89030; font-family: 'Eczar', serif; font-size: 14.3px; line-height: 1.55; }
  .qd-brief-line { margin: 0 0 4px; color: #2a1f15; }
  .qd-brief-line:last-child { margin-bottom: 0; }
  .qd-brief-line strong { color: #c44a2a; font-weight: 700; font-style: normal; letter-spacing: 1px; text-transform: uppercase; font-size: 12.1px; }
  .qd-brief-arrow { padding-left: 14px; position: relative; }
  .qd-brief-arrow::before { content: '→'; position: absolute; left: 0; color: #c44a2a; font-weight: 800; }
  .qd-next { margin-top: 18px; padding: 14px 18px; background: rgba(196,74,42,0.05); border: 2px solid #c44a2a; }
  .qd-next-title { margin: 0 0 8px; font-family: 'Eczar', serif; font-weight: 700; font-size: 13.2px; letter-spacing: 3px; color: #c44a2a; text-transform: uppercase; }
  .qd-next-summary { display: flex; align-items: center; gap: 10px; cursor: pointer; list-style: none; }
  .qd-next-summary::-webkit-details-marker { display: none; }
  .qd-next-text { font-family: 'Eczar', serif; font-weight: 700; color: #4a2e1a; font-size: 17.6px; flex: 1; line-height: 1.4; }
  .qd-next-arrow { color: #c44a2a; font-size: 15.4px; transition: transform 0.2s ease; }
  .qd-next-details[open] .qd-next-arrow { transform: rotate(90deg); }
  .qd-next-brief { margin: 8px 0 0 24px; padding: 10px 12px; background: #fbf3df; border: 1px solid #c89030; font-family: 'Eczar', serif; font-size: 14.3px; line-height: 1.55; }
  .qd-meta { margin-top: 16px; padding: 14px 18px; background: #f3e6c4; border: 2px solid #8a6f4a; display: grid; gap: 4px; }
  .qd-meta-row { display: grid; grid-template-columns: 110px 1fr; gap: 10px; align-items: baseline; padding: 5px 0; border-bottom: 1px dotted rgba(138,111,74,0.3); font-family: 'Eczar', serif; }
  .qd-meta-row:last-child { border-bottom: none; }
  .qd-meta dt, .qd-meta dd { margin: 0; }
  .qd-meta dt { font-weight: 700; font-size: 12.1px; letter-spacing: 2.5px; color: #7a5a3a; text-transform: uppercase; font-style: normal; }
  .qd-meta dd { font-size: 14.3px; color: #2a1f15; word-break: break-word; }
  .qd-meta code { font-family: ui-monospace, monospace; background: #fbf3df; padding: 1px 5px; border: 1px solid #c89030; font-size: 13.2px; }
  .qd-progress { position: relative; height: 16px; background: #fbf3df; border: 2px solid #4a2e1a; overflow: hidden; margin-top: 6px; }
  .qd-progress-fill { height: 100%; background: linear-gradient(180deg, #c44a2a 0%, #8a2818 100%); }
  .qd-progress-label { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-family: 'Eczar', serif; font-weight: 700; font-size: 11px; color: #4a2e1a; }
  /* Links section — storybook theme */
  .qd-links { margin-top: 22px; padding: 16px 18px; background: #fbf3df; border: 1.5px solid #4a2e1a; }
  .qd-links-title { margin: 0 0 12px; font-family: 'Eczar', serif; font-weight: 700; font-size: 13.2px; letter-spacing: 2.5px; color: #4a2e1a; text-transform: uppercase; }
  .qd-links-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
  .qd-link { padding: 0; }
  .qd-link-anchor { display: grid; grid-template-columns: 1fr auto; column-gap: 14px; row-gap: 4px; padding: 10px 12px; background: #fffdf6; border-bottom: 1px dashed #c89030; text-decoration: none; color: #2a1f15; }
  .qd-link-anchor:hover { background: #fff0c8; border-bottom-style: solid; }
  .qd-link-label { grid-column: 1; grid-row: 1; font-family: 'Eczar', serif; font-weight: 700; font-size: 15.4px; color: #c44a2a; align-self: baseline; }
  .qd-link-url { grid-column: 2; grid-row: 1; font-family: ui-monospace, monospace; font-size: 11.5px; color: #7a5a3a; text-align: right; max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; align-self: baseline; }
  .qd-link-desc { grid-column: 1 / -1; grid-row: 2; font-size: 13.2px; color: #4a2e1a; font-style: italic; }
  @media (max-width: 720px) {
    .qd-link-anchor { grid-template-columns: 1fr; }
    .qd-link-label { grid-column: 1; grid-row: 1; }
    .qd-link-url { grid-column: 1; grid-row: 3; text-align: left; max-width: 100%; }
    .qd-link-desc { grid-column: 1; grid-row: 2; }
  }
  /* Multi-active: ?q=<id> dispatcher hides all blocks but the matching one. */
  .qd-quest-block { display: none; }
  .qd-quest-block.qd-active { display: block; }
  .qd-active-picker { max-width: 1280px; margin: 0 auto 14px; padding: 8px 14px; background: #fbf3df; border: 2.5px solid #4a2e1a; display: flex; flex-wrap: wrap; align-items: center; gap: 10px; font-family: 'Eczar', serif; }
  .qd-active-picker-label { font-weight: 700; font-size: 12.1px; letter-spacing: 2.5px; color: #7a5a3a; text-transform: uppercase; }
  .qd-active-picker-list { display: flex; flex-wrap: wrap; gap: 6px; }
  .qd-active-picker a { padding: 4px 12px; background: #fffdf6; border: 1.5px solid #4a2e1a; font-weight: 700; font-size: 13.2px; color: #4a2e1a; text-decoration: none; }
  .qd-active-picker a.qd-active-picker-current { background: #c44a2a; color: #fbf3df; }
  .qd-active-picker a:hover { background: #f0c050; }
  /* Two-section split + collapse summary */
  .qd-tasks-summary { display: flex; align-items: center; gap: 8px; cursor: pointer; list-style: none; padding: 4px 0; }
  .qd-tasks-summary::-webkit-details-marker { display: none; }
  .qd-tasks-summary-arrow { color: #c44a2a; font-size: 14.3px; transition: transform 0.2s ease; opacity: 0.7; flex-shrink: 0; }
  details[open] > .qd-tasks-summary > .qd-tasks-summary-arrow { transform: rotate(90deg); opacity: 1; }
  .qd-tasks-summary-preview { font-family: 'Eczar', serif; font-style: italic; font-size: 14.3px; color: #7a5a3a; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .qd-user-tasks { margin-top: 22px; padding: 18px 22px; background: rgba(58,138,160,0.06); border: 2px solid #3a8aa0; }
  .qd-user-tasks .qd-tasks-title { color: #3a8aa0; }
  .qd-user-tasks .qd-tasks-count { color: #3a8aa0; }
  /* Rich actions sections — Your Actions / Claude's Actions. Storybook palette. */
  .qd-actions { margin-top: 26px; padding: 18px 22px; border: 1.5px solid #4a2e1a; background: #fbf3df; }
  .qd-actions-claude { border-color: #7a5a3a; background: rgba(200,176,154,0.18); }
  .qd-actions-user   { border-color: #c44a2a; background: rgba(196,74,42,0.06); }
  .qd-actions-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px dashed #c89030; }
  .qd-actions-icon { display: inline-flex; align-items: center; justify-content: center; }
  .qd-actions-icon svg { display: block; }
  .qd-actions-title { margin: 0; font-family: 'Eczar', serif; font-weight: 700; font-size: 19.8px; color: #4a2e1a; flex: 1; letter-spacing: 0.3px; }
  .qd-actions-claude .qd-actions-title { color: #7a5a3a; }
  .qd-actions-user   .qd-actions-title { color: #c44a2a; }
  .qd-actions-count { font-family: 'Eczar', serif; font-weight: 700; font-size: 13.2px; padding: 2px 10px; background: #fffdf6; border: 1.5px solid #4a2e1a; color: #4a2e1a; }
  .qd-actions-list { list-style: none; padding: 0; margin: 0; }
  .qd-action { display: grid; grid-template-columns: 36px 1fr; gap: 14px; padding: 14px 0; border-bottom: 1px dotted #c89030; align-items: start; }
  .qd-action:last-child { border-bottom: none; padding-bottom: 0; }
  .qd-action-num { width: 30px; height: 30px; border-radius: 50%; background: #c89030; border: 1.5px solid #4a2e1a; display: flex; align-items: center; justify-content: center; font-family: 'Eczar', serif; font-weight: 700; font-size: 14.3px; color: #fbf3df; line-height: 1; }
  .qd-actions-claude .qd-action-num { background: #7a5a3a; }
  .qd-actions-user .qd-action-num { background: #c44a2a; }
  .qd-action-body { font-family: 'Eczar', serif; font-size: 15.4px; line-height: 1.6; color: #2a1f15; }
  .qd-action-head { margin: 0 0 8px; font-weight: 700; font-size: 16.5px; color: #4a2e1a; line-height: 1.3; }
  .qd-action-body p { margin: 0 0 6px; }
  .qd-action-body p:last-child { margin-bottom: 0; }
  .qd-action-body code { font-family: ui-monospace, monospace; background: #f3e6c4; padding: 1px 6px; border: 1px solid #c89030; font-size: 13.2px; font-style: normal; }
  .qd-action-body a { color: #c44a2a; font-weight: 700; text-decoration: none; border-bottom: 1px dashed #c44a2a; }
  .qd-action-body a:hover { background: #f3e6c4; border-bottom-style: solid; }
  .qd-action-status { display: inline-block; margin-left: 8px; padding: 1px 9px; font-family: 'Eczar', serif; font-size: 11.5px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; vertical-align: middle; }
  .qd-action-status-pill-todo       { background: #f0c050; color: #4a2e1a; border: 1px solid #c89030; }
  .qd-action-status-pill-done       { background: #d8e0a8; color: #4a2e1a; border: 1px solid #8a9050; }
  .qd-action-status-pill-waiting    { background: #d8d4c8; color: #4a2e1a; border: 1px solid #8a8478; }
  .qd-action-status-pill-queued     { background: #c8d8e8; color: #2a4a6a; border: 1px solid #6a8aa8; }
  .qd-action-status-pill-continuous { background: #b8d4c8; color: #2a4a3a; border: 1px solid #5a8a78; }
  .qd-action-status-pill-default    { background: #f3e6c4; color: #4a2e1a; border: 1px solid #c89030; }
  .qd-action-status-done .qd-action-head { color: #5a6a3a; text-decoration: line-through; }
  .qd-action-status-done .qd-action-num  { background: #8a9050; }
  /* Problem/Solution brief lines with inline icons */
  .qd-brief-line .qd-brief-icon { display: inline-flex; vertical-align: -2px; margin-right: 6px; color: #4a2e1a; }
  .qd-brief-problem .qd-brief-icon { color: #c44a2a; }
  .qd-brief-solution .qd-brief-icon { color: #c89030; }
  /* Collapsible summary header for actions sections (collapsed by default) */
  .qd-actions details > summary { display: block; cursor: pointer; list-style: none; padding: 4px 0 12px; border-bottom: 1px dashed #c89030; }
  .qd-actions details > summary::-webkit-details-marker { display: none; }
  .qd-actions details[open] > summary { margin-bottom: 14px; }
  .qd-actions-summary-head { display: flex; align-items: center; gap: 10px; }
  .qd-actions-summary-arrow { color: #c44a2a; font-size: 14.3px; transition: transform 0.2s ease; opacity: 0.7; flex-shrink: 0; }
  .qd-actions details[open] > summary .qd-actions-summary-arrow { transform: rotate(90deg); opacity: 1; }
  .qd-actions details[open] > summary .qd-actions-summary-next3 { display: none; }
  .qd-actions-summary-next3 { list-style: none; margin: 10px 0 0; padding: 0 0 0 32px; display: grid; gap: 4px; font-family: 'Eczar', serif; }
  .qd-actions-summary-next3 > li { display: flex; align-items: baseline; gap: 8px; font-size: 14.3px; padding: 3px 0; line-height: 1.4; color: #4a2e1a; }
  .qd-actions-summary-num { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; background: #fbf3df; border: 1px solid #8a6f4a; font-weight: 700; font-size: 11.5px; color: #4a2e1a; flex-shrink: 0; line-height: 1; }
  .qd-actions-summary-title { font-style: italic; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
  .qd-actions-summary-next3 .qd-action-status { font-size: 10px; padding: 1px 7px; }
  .qd-actions-summary-next3 li.qd-action-status-done .qd-actions-summary-title { text-decoration: line-through; opacity: 0.6; }
  /* Empty-state placeholder */
  .qd-actions.qd-actions-empty { padding: 14px 20px; opacity: 0.85; border-style: dashed; border-width: 1.5px; }
  .qd-actions-empty .qd-actions-summary-head { padding-bottom: 8px; border-bottom: 1px dashed #c89030; margin-bottom: 8px; }
  .qd-actions-empty-badge { font-family: 'Eczar', serif; font-size: 11px; font-weight: 700; padding: 2px 9px; background: #fbf3df; color: #7a5a3a; border: 1px dashed #7a5a3a; letter-spacing: 1px; text-transform: uppercase; }
  .qd-actions-empty-hint { margin: 0; font-family: 'Eczar', serif; font-size: 13.5px; line-height: 1.55; color: #7a5a3a; font-style: italic; }
  .qd-actions-empty-hint code { font-family: ui-monospace, monospace; background: #fbf3df; padding: 1px 6px; border: 1px solid #c89030; font-size: 12.5px; color: #4a2e1a; font-style: normal; }
  .qd-actions-empty-hint a { color: #c44a2a; font-weight: 700; }
</style>
</head>
<body>
{{{active_picker_html}}}
{{{quest_blocks_html}}}
<script>
(function() {
  var pid = (location.pathname.split('/').filter(Boolean)[0]) || 'default';
  var defaultQid = {{{default_quest_json}}};
  var params = new URLSearchParams(location.search);
  var requested = params.get('q') || defaultQid;
  function activate(qid) {
    var blocks = document.querySelectorAll('.qd-quest-block');
    var found = null;
    blocks.forEach(function(b) {
      if (b.getAttribute('data-quest-id') === qid) {
        b.classList.add('qd-active'); found = b;
      } else {
        b.classList.remove('qd-active');
      }
    });
    if (!found && blocks.length) {
      blocks[0].classList.add('qd-active'); found = blocks[0];
    }
    if (found) {
      var name = found.getAttribute('data-quest-name') || '';
      var n = found.getAttribute('data-quest-n') || '';
      if (name) document.title = (document.title.split(' — ')[0]) + ' — Chapter ' + n + ': ' + name;
    }
    document.querySelectorAll('.qd-active-picker a').forEach(function(a) {
      a.classList.toggle('qd-active-picker-current', a.getAttribute('data-qid') === qid);
    });
  }
  activate(requested);

  var FILTER_KEY = 'qd-filter-' + pid;
  function loadFilter() {
    try { return JSON.parse(localStorage.getItem(FILTER_KEY)) || {}; } catch (e) { return {}; }
  }
  function saveFilter(s) {
    try { localStorage.setItem(FILTER_KEY, JSON.stringify(s)); } catch (e) {}
  }
  var fState = loadFilter();
  function applyFilter() {
    document.body.classList.toggle('hide-done-deeds', !!fState.hideDoneDeeds);
    document.querySelectorAll('.qd-deeds-toggle').forEach(function(btn) {
      btn.classList.toggle('on', !!fState.hideDoneDeeds);
      btn.setAttribute('aria-pressed', fState.hideDoneDeeds ? 'true' : 'false');
    });
  }
  document.querySelectorAll('.qd-deeds-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      fState.hideDoneDeeds = !fState.hideDoneDeeds;
      saveFilter(fState); applyFilter();
    });
  });
  applyFilter();

  function collapseKey(qid, section) {
    return 'qd-collapse-' + pid + '-' + qid + '-' + section;
  }
  document.querySelectorAll('details[data-qd-collapse]').forEach(function(det) {
    var section = det.getAttribute('data-qd-collapse');
    var qBlock = det.closest('.qd-quest-block');
    var qid = qBlock ? qBlock.getAttribute('data-quest-id') : 'default';
    var k = collapseKey(qid, section);
    var stored = null;
    try { stored = localStorage.getItem(k); } catch (e) {}
    if (stored === 'open') det.open = true;
    else if (stored === 'closed') det.open = false;
    det.addEventListener('toggle', function() {
      try { localStorage.setItem(k, det.open ? 'open' : 'closed'); } catch (e) {}
    });
  });
})();
</script>
</body>
</html>
