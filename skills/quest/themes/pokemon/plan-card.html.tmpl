<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{name}} — Quest {{active.n}}: {{active.name}}</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; }
  body { margin: 0; min-height: 100vh; font-family: 'Fredoka', system-ui, sans-serif; background: #5db4d8; padding: 18px; color: #2a3a4a; }
  .frame { max-width: 1280px; margin: 0 auto; background: #fffdf2; border: 4px solid #2a3a4a; border-radius: 16px; overflow: hidden; box-shadow: 0 12px 30px rgba(20,40,60,0.4); }
  .head { padding: 14px 22px; background: linear-gradient(180deg, #fff 0%, #f7eed8 100%); border-bottom: 4px solid #2a3a4a; display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; }
  .title { display: flex; align-items: center; gap: 12px; }
  .badge { width: 50px; height: 50px; background: #ffd24a; border: 3px solid #2a3a4a; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 22px; color: #2a3a4a; box-shadow: 0 3px 0 #c9a020; line-height: 1; }
  h1 { margin: 0; font-weight: 700; font-size: 26px; color: #2a3a4a; line-height: 1.1; }
  .sub { font-weight: 500; font-size: 14px; color: #6a7a8a; margin-top: 2px; }
  .nav { display: flex; gap: 6px; margin: 0 8px; }
  .nav a { padding: 8px 14px; background: #fffdf2; border: 2.5px solid #2a3a4a; border-radius: 10px; font-weight: 700; font-size: 13px; color: #2a3a4a; text-decoration: none; letter-spacing: 1px; text-transform: uppercase; }
  .crumbs { padding: 12px 22px; background: #f7eed8; border-bottom: 3px solid #2a3a4a; display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 14px; color: #6a7a8a; }
  .crumbs a { color: #2a3a4a; text-decoration: none; padding: 4px 10px; border: 2px solid #2a3a4a; border-radius: 8px; background: #fffdf2; font-weight: 700; }
  .crumbs .here { padding: 4px 10px; background: #ff6a3a; color: #fff; border-radius: 8px; border: 2px solid #5a1818; font-weight: 700; }
  .body { display: grid; grid-template-columns: 1.1fr 1fr; gap: 0; }
  .illus-cell { background: linear-gradient(180deg, #bbe4f5 0%, #bbe4f5 28%, #8fc97a 28%); border-right: 4px solid #2a3a4a; padding: 24px; min-height: 480px; }
  .illus-cell svg { width: 100%; height: auto; display: block; }
  .info-cell { padding: 24px 28px; background: #fffdf2; }
  .quest-no { font-weight: 700; font-size: 14px; letter-spacing: 3px; color: #ff6a3a; text-transform: uppercase; margin-bottom: 4px; }
  .quest-title { margin: 0; font-weight: 700; font-size: 32px; color: #5a1818; line-height: 1.1; letter-spacing: 0.3px; }
  .stat-row { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
  .pill { padding: 6px 12px; background: #ffd24a; border: 2.5px solid #5a1818; border-radius: 14px; font-weight: 700; font-size: 13px; color: #5a1818; line-height: 1; }
  .pill.type { background: #ff6a3a; color: #fff; }
  .stats-block { margin-top: 22px; padding: 16px 18px; background: #f7eed8; border: 3px solid #2a3a4a; border-radius: 12px; }
  .stats-h { font-weight: 700; font-size: 12px; letter-spacing: 2.5px; color: #2a3a4a; text-transform: uppercase; margin-bottom: 12px; }
  .stat-line { display: grid; grid-template-columns: 88px 1fr 64px; gap: 10px; align-items: center; margin-bottom: 8px; font-weight: 600; font-size: 14px; }
  .stat-line .barbg { height: 10px; background: #fffdf2; border: 2px solid #2a3a4a; border-radius: 6px; overflow: hidden; }
  .stat-line .barfill { height: 100%; background: linear-gradient(180deg, #ff8a4a 0%, #ff5a20 100%); }
  .stat-line .v { text-align: right; font-weight: 700; }
  .desc { margin-top: 22px; padding: 16px 18px; background: #fffdf2; border: 3px solid #2a3a4a; border-radius: 12px; }
  .desc-h { font-weight: 700; font-size: 12px; letter-spacing: 2.5px; color: #6a7a8a; text-transform: uppercase; margin-bottom: 8px; }
  .desc p { margin: 0 0 8px; font-size: 15px; line-height: 1.55; }
  .next-step { margin-top: 18px; padding: 16px 18px; background: rgba(255,106,58,0.06); border: 3px solid #ff6a3a; border-radius: 12px; }
  .next-step h3 { font-weight: 700; font-size: 12px; letter-spacing: 2.5px; color: #5a1818; text-transform: uppercase; margin: 0 0 6px; }
  .next-step p { margin: 0; font-size: 15px; font-weight: 600; color: #5a1818; line-height: 1.45; }
  .actions { display: flex; gap: 10px; margin-top: 22px; flex-wrap: wrap; }
  .btn { padding: 10px 16px; border: 3px solid #2a3a4a; border-radius: 12px; font-weight: 700; font-size: 14px; cursor: pointer; box-shadow: 0 4px 0 #2a3a4a; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
  .btn.primary { background: #ff6a3a; color: #fff; border-color: #5a1818; box-shadow: 0 4px 0 #5a1818; }
  .btn.ghost { background: #fffdf2; color: #2a3a4a; }
  .meta-line { margin-top: 18px; font-size: 13px; color: #6a7a8a; padding-top: 14px; border-top: 2px dashed #c0a878; }
  code { font-family: ui-monospace, monospace; background: #f7eed8; padding: 2px 6px; border-radius: 4px; }
  .twinkle { animation: tw 1.6s ease-in-out infinite; transform-origin: center; transform-box: fill-box; }
  @keyframes tw { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.08); opacity: 0.85; } }

  /* shared partial CSS — pokemon theme */
  .qd-back-link { display: inline-block; padding: 6px 12px; background: #fffdf2; border: 2.5px solid #2a3a4a; border-radius: 10px; color: #2a3a4a; text-decoration: none; font-weight: 700; font-size: 13px; letter-spacing: 1px; text-transform: uppercase; box-shadow: 0 3px 0 #2a3a4a; }
  .qd-back-link:hover { transform: translateY(1px); box-shadow: 0 2px 0 #2a3a4a; }
  .qd-pills { display: flex; flex-wrap: wrap; gap: 6px; margin: 10px 0 4px; }
  /* When .qd-pills is nested inside .stat-row, promote its children to flex
     siblings of stat-row's other pills so they wrap on the same line. */
  .stat-row .qd-pills { display: contents; }
  .qd-pill { padding: 4px 10px; font-size: 12px; font-weight: 600; color: #2a3a4a; background: #fffdf2; border: 2px solid #2a3a4a; border-radius: 12px; line-height: 1.3; white-space: nowrap; min-width: 0; max-width: 100%; overflow: hidden; text-overflow: ellipsis; }
  .qd-pill-kpi { white-space: normal; overflow-wrap: anywhere; word-break: break-word; text-overflow: clip; }
  .qd-pill-branch { background: #d8eaf5; }
  .qd-pill-kpi { background: #fff0c8; }
  .qd-pill-tags { background: #ffe0d0; }
  .qd-why { margin: 10px 0 0; padding: 10px 14px; background: rgba(255,106,58,0.08); border-left: 3px solid #ff6a3a; font-size: 14px; font-style: italic; color: #5a3a2a; line-height: 1.5; }
  .qd-why-mark { color: #ff6a3a; font-style: normal; margin-right: 6px; }
  .qd-tasks { margin-top: 18px; padding: 16px 18px; background: #fffdf2; border: 3px solid #2a3a4a; border-radius: 12px; }
  .qd-tasks-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px; }
  .qd-tasks-title { margin: 0; font-weight: 700; font-size: 12px; letter-spacing: 2.5px; color: #2a3a4a; text-transform: uppercase; }
  .qd-tasks-count { font-weight: 700; font-size: 13px; color: #ff6a3a; }
  .qd-deeds-toggle { margin-left: auto; padding: 4px 10px; background: #fffdf2; border: 2px solid #2a3a4a; border-radius: 10px; font-family: inherit; font-weight: 700; font-size: 12px; color: #2a3a4a; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; letter-spacing: 0.5px; transition: transform 0.1s ease; }
  .qd-deeds-toggle:hover { transform: translateY(-1px); box-shadow: 0 2px 0 #2a3a4a; }
  .qd-deeds-toggle:focus-visible { outline: 2px solid #ff6a3a; outline-offset: 2px; }
  .qd-deeds-toggle.on { background: #2a3a4a; color: #ffd24a; border-color: #2a3a4a; }
  .qd-toggle-mark { display: inline-block; width: 14px; height: 14px; border: 2px solid currentColor; border-radius: 3px; text-align: center; font-weight: 800; line-height: 10px; font-size: 11px; }
  .qd-deeds-toggle.on .qd-toggle-mark::before { content: '✓'; }
  body.hide-done-deeds .qd-task.qd-task-done { display: none; }
  /* Storyline link styles + plan-file chips (used in qd-meta) */
  .qd-storyline-link { color: #c44a2a; font-weight: 700; text-decoration: none; border-bottom: 1px dashed #c44a2a; }
  .qd-storyline-link:hover { background: #ffd9b8; border-bottom-style: solid; }
  .qd-storyline-arrow { color: #ff6a3a; font-weight: 800; }
  .qd-plan-chip { display: inline-block; margin: 2px 4px 2px 0; padding: 2px 8px; background: #fffdf2; border: 2px solid #2a3a4a; border-radius: 8px; font-family: ui-monospace, monospace; font-size: 12px; font-weight: 600; color: #2a3a4a; }
  .qd-tasks-list { list-style: none; padding: 0; margin: 0; }
  .qd-task { padding: 6px 0; font-size: 14px; border-bottom: 1px dashed rgba(42,58,74,0.15); }
  .qd-task:last-child { border-bottom: none; }
  .qd-task > span { display: inline-flex; align-items: flex-start; gap: 8px; }
  .qd-task-summary { display: flex; align-items: center; gap: 8px; cursor: pointer; list-style: none; padding: 2px 0; }
  .qd-task-summary::-webkit-details-marker { display: none; }
  .qd-task-mark { display: inline-block; width: 18px; height: 18px; border: 2px solid #2a3a4a; border-radius: 4px; text-align: center; font-weight: 800; line-height: 14px; font-size: 13px; flex-shrink: 0; }
  .qd-task-done .qd-task-mark { background: #5e9a4a; color: #fff; border-color: #2e5a2e; }
  .qd-task-done .qd-task-title { color: #6a7a8a; text-decoration: line-through; }
  .qd-task-todo .qd-task-mark { background: #fffdf2; color: transparent; }
  .qd-task-title { font-weight: 600; color: #2a3a4a; flex: 1; }
  .qd-task-arrow { color: #ff6a3a; font-size: 13px; transition: transform 0.2s ease; opacity: 0.7; }
  .qd-task-details[open] .qd-task-arrow { transform: rotate(90deg); opacity: 1; }
  .qd-task-brief { margin: 6px 0 6px 26px; padding: 10px 12px; background: #f7eed8; border-radius: 8px; border: 2px solid #c0a878; font-size: 13px; }
  .qd-brief-line { margin: 0 0 4px; line-height: 1.5; color: #2a3a4a; }
  .qd-brief-line:last-child { margin-bottom: 0; }
  .qd-brief-line strong { color: #5a1818; font-weight: 700; }
  .qd-brief-arrow { padding-left: 14px; position: relative; }
  .qd-brief-arrow::before { content: '→'; position: absolute; left: 0; color: #ff6a3a; font-weight: 800; }
  .qd-next { margin-top: 18px; padding: 14px 18px; background: rgba(255,106,58,0.06); border: 3px solid #ff6a3a; border-radius: 12px; }
  .qd-next-title { margin: 0 0 8px; font-weight: 700; font-size: 12px; letter-spacing: 2.5px; color: #5a1818; text-transform: uppercase; }
  .qd-next-summary { display: flex; align-items: center; gap: 8px; cursor: pointer; list-style: none; }
  .qd-next-summary::-webkit-details-marker { display: none; }
  .qd-next-text { font-weight: 600; color: #5a1818; font-size: 15px; flex: 1; }
  .qd-next-arrow { color: #ff6a3a; font-size: 15px; transition: transform 0.2s ease; }
  .qd-next-details[open] .qd-next-arrow { transform: rotate(90deg); }
  .qd-next-brief { margin: 8px 0 0 22px; padding: 10px 12px; background: #fffdf2; border-radius: 8px; border: 2px solid #c0a878; font-size: 13px; }
  .qd-meta { margin-top: 16px; padding: 14px 16px; background: #f7eed8; border: 3px solid #2a3a4a; border-radius: 12px; display: grid; gap: 6px; }
  .qd-meta dt, .qd-meta dd { margin: 0; font-size: 13px; }
  .qd-meta-row { display: grid; grid-template-columns: 110px 1fr; gap: 10px; align-items: baseline; padding: 4px 0; border-bottom: 1px dashed rgba(42,58,74,0.15); }
  .qd-meta-row:last-child { border-bottom: none; }
  .qd-meta dt { font-weight: 700; font-size: 12px; letter-spacing: 1.5px; color: #6a7a8a; text-transform: uppercase; }
  .qd-meta dd { font-weight: 600; color: #2a3a4a; word-break: break-word; }
  .qd-meta code { font-family: ui-monospace, monospace; background: #fffdf2; padding: 2px 5px; border-radius: 4px; border: 1px solid #c0a878; font-size: 12px; font-weight: 600; }
  .qd-progress { position: relative; height: 18px; background: #fffdf2; border: 2.5px solid #2a3a4a; border-radius: 10px; overflow: hidden; margin-top: 6px; }
  .qd-progress-fill { height: 100%; background: linear-gradient(180deg, #ff8a4a 0%, #ff5a20 100%); transition: width 0.3s ease; }
  .qd-progress-label { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; color: #2a3a4a; }
  /* Links section — pokemon theme */
  .qd-links { margin-top: 18px; padding: 16px 18px; background: #fffdf2; border: 3px solid #2a3a4a; border-radius: 12px; }
  .qd-links-title { margin: 0 0 12px; font-weight: 700; font-size: 12px; letter-spacing: 2.5px; color: #2a3a4a; text-transform: uppercase; }
  .qd-links-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
  .qd-link { padding: 0; }
  .qd-link-anchor { display: grid; grid-template-columns: minmax(0, 1fr) auto; column-gap: 14px; row-gap: 4px; padding: 10px 12px; background: #f7eed8; border: 2px solid #2a3a4a; border-radius: 8px; text-decoration: none; color: #2a3a4a; transition: transform 0.08s ease; }
  .qd-link-anchor:hover { transform: translateY(-1px); background: #fff0c8; box-shadow: 0 2px 0 #2a3a4a; }
  .qd-link-label { grid-column: 1; grid-row: 1; font-weight: 700; font-size: 14px; color: #5a1818; align-self: baseline; min-width: 0; overflow-wrap: anywhere; word-break: break-word; }
  .qd-link-url { grid-column: 2; grid-row: 1; font-family: ui-monospace, monospace; font-size: 12px; color: #6a7a8a; text-align: right; max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; align-self: baseline; }
  .qd-link-desc { grid-column: 1 / -1; grid-row: 2; font-weight: 500; font-size: 13px; color: #2a3a4a; }
  @media (max-width: 720px) {
    .qd-link-anchor { grid-template-columns: 1fr; }
    .qd-link-label { grid-column: 1; grid-row: 1; }
    .qd-link-url { grid-column: 1; grid-row: 3; text-align: left; max-width: 100%; }
    .qd-link-desc { grid-column: 1; grid-row: 2; }
  }
  /* Multi-active: ?q=<id> dispatcher hides all blocks but the matching one. */
  .qd-quest-block { display: none; }
  .qd-quest-block.qd-active { display: block; }
  /* Multi-active picker — small bar above the quest body listing all currents. */
  .qd-active-picker { max-width: 1280px; margin: 0 auto 14px; padding: 8px 14px; background: #fffdf2; border: 3px solid #2a3a4a; border-radius: 12px; display: flex; flex-wrap: wrap; align-items: center; gap: 10px; box-shadow: 0 4px 0 #2a3a4a; }
  .qd-active-picker-label { font-weight: 700; font-size: 12px; letter-spacing: 2px; color: #6a7a8a; text-transform: uppercase; }
  .qd-active-picker-list { display: flex; flex-wrap: wrap; gap: 6px; }
  .qd-active-picker a { padding: 4px 10px; background: #f7eed8; border: 2px solid #2a3a4a; border-radius: 8px; font-weight: 700; font-size: 13px; color: #2a3a4a; text-decoration: none; }
  .qd-active-picker a.qd-active-picker-current { background: #ff6a3a; color: #fff; border-color: #5a1818; }
  .qd-active-picker a:hover { background: #ffd24a; }
  /* Two-section split: Deeds (Claude) + To-Do (User). Both <details>; collapsed default. */
  .qd-tasks-summary { display: flex; align-items: center; gap: 8px; cursor: pointer; list-style: none; padding: 4px 0; }
  .qd-tasks-summary::-webkit-details-marker { display: none; }
  .qd-tasks-summary-arrow { color: #ff6a3a; font-size: 13px; transition: transform 0.2s ease; opacity: 0.7; flex-shrink: 0; }
  details[open] > .qd-tasks-summary > .qd-tasks-summary-arrow { transform: rotate(90deg); opacity: 1; }
  .qd-tasks-summary-preview { font-weight: 600; font-size: 13px; color: #6a7a8a; font-style: italic; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .qd-user-tasks { margin-top: 18px; padding: 16px 18px; background: #fff; border: 3px solid #5a8aa0; border-radius: 12px; }
  .qd-user-tasks .qd-tasks-title { color: #2a5a8a; }
  .qd-user-tasks .qd-tasks-count { color: #2a5a8a; }
  .qd-user-tasks .qd-task-mark { border-color: #2a5a8a; }
  .qd-user-tasks .qd-task-done .qd-task-mark { background: #5a8aa0; border-color: #2a5a8a; }
  /* Rich actions sections — Your Actions / Claude's Actions. Flat numbered list. */
  .qd-actions { margin-top: 22px; padding: 18px 20px; border: 3px solid #2a3a4a; border-radius: 12px; }
  .qd-actions-claude { background: rgba(91,180,216,0.08); border-color: #5a1818; }
  .qd-actions-user   { background: rgba(255,210,74,0.10); border-color: #ff6a3a; }
  .qd-actions-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 2px dashed rgba(42,58,74,0.25); }
  .qd-actions-icon { display: inline-flex; align-items: center; justify-content: center; }
  .qd-actions-icon svg { display: block; }
  .qd-actions-title { margin: 0; font-weight: 700; font-size: 16px; color: #2a3a4a; flex: 1; }
  .qd-actions-claude .qd-actions-title { color: #5a1818; }
  .qd-actions-user   .qd-actions-title { color: #c45a18; }
  .qd-actions-count { font-weight: 700; font-size: 12px; padding: 3px 10px; border-radius: 12px; background: #fffdf2; border: 2px solid #2a3a4a; color: #2a3a4a; }
  .qd-actions-list { list-style: none; padding: 0; margin: 0; counter-reset: action-num; }
  .qd-action { display: grid; grid-template-columns: 32px 1fr; gap: 12px; padding: 12px 0; border-bottom: 1px dashed rgba(42,58,74,0.18); align-items: start; }
  .qd-action:last-child { border-bottom: none; padding-bottom: 0; }
  .qd-action-num { width: 28px; height: 28px; border-radius: 50%; background: #ffd24a; border: 2px solid #5a1818; box-shadow: 0 2px 0 #c9a020; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; color: #5a1818; line-height: 1; }
  .qd-actions-claude .qd-action-num { background: #bcd4dd; border-color: #2a5a8a; box-shadow: 0 2px 0 #2a5a8a; color: #1a4a8a; }
  .qd-actions-user .qd-action-num { background: #ffd24a; border-color: #c45a18; box-shadow: 0 2px 0 #c45a18; color: #5a1818; }
  .qd-action-body { font-size: 14px; line-height: 1.5; color: #2a3a4a; }
  .qd-action-head { margin: 0 0 6px; font-weight: 700; font-size: 14px; color: #2a3a4a; line-height: 1.35; }
  .qd-action-body p { margin: 0 0 6px; }
  .qd-action-body p:last-child { margin-bottom: 0; }
  .qd-action-body code { font-family: ui-monospace, monospace; background: #f7eed8; padding: 1px 5px; border-radius: 4px; font-size: 13px; }
  .qd-action-body a { color: #c44a2a; font-weight: 600; text-decoration: none; border-bottom: 1px dashed #c44a2a; }
  .qd-action-body a:hover { background: #ffd9b8; border-bottom-style: solid; }
  /* Status pill — colour buckets */
  .qd-action-status { display: inline-block; margin-left: 8px; padding: 2px 8px; border-radius: 11px; font-size: 11px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; vertical-align: middle; }
  .qd-action-status-pill-todo       { background: #fff0c8; color: #6a4a1a; border: 1px solid #c0a878; }
  .qd-action-status-pill-done       { background: #d8f0c8; color: #2a5a1a; border: 1px solid #5e9a4a; }
  .qd-action-status-pill-waiting    { background: #e8e8e8; color: #555;    border: 1px solid #999; }
  .qd-action-status-pill-queued     { background: #d8eaf5; color: #1a4a8a; border: 1px solid #3a8ae6; }
  .qd-action-status-pill-continuous { background: #c8e8e0; color: #1a5a4a; border: 1px solid #3a9080; }
  .qd-action-status-pill-default    { background: #f0f0f0; color: #444;    border: 1px solid #aaa; }
  .qd-action-status-done .qd-action-head { color: #2a5a1a; text-decoration: line-through; }
  .qd-action-status-done .qd-action-num  { background: #5e9a4a; color: #fff; border-color: #2a5a1a; box-shadow: 0 2px 0 #2a5a1a; }
  /* Problem/Solution brief lines with inline icons */
  .qd-brief-line .qd-brief-icon { display: inline-flex; vertical-align: -2px; margin-right: 6px; color: #5a1818; }
  .qd-brief-problem .qd-brief-icon { color: #c44a2a; }
  .qd-brief-solution .qd-brief-icon { color: #c9a020; }
  /* Collapsible summary header for actions sections (collapsed by default) */
  .qd-actions details > summary { display: block; cursor: pointer; list-style: none; padding: 4px 0 12px; border-bottom: 2px dashed rgba(42,58,74,0.25); }
  .qd-actions details > summary::-webkit-details-marker { display: none; }
  .qd-actions details[open] > summary { margin-bottom: 14px; }
  .qd-actions-summary-head { display: flex; align-items: center; gap: 10px; }
  .qd-actions-summary-arrow { color: #ff6a3a; font-size: 14px; transition: transform 0.2s ease; opacity: 0.7; flex-shrink: 0; }
  .qd-actions details[open] > summary .qd-actions-summary-arrow { transform: rotate(90deg); opacity: 1; }
  /* Next-3 peek inside the collapsed <summary> — hidden when section open */
  .qd-actions details[open] > summary .qd-actions-summary-next3 { display: none; }
  .qd-actions-summary-next3 { list-style: none; margin: 10px 0 0; padding: 0 0 0 30px; display: grid; gap: 4px; }
  .qd-actions-summary-next3 > li { display: flex; align-items: baseline; gap: 8px; font-size: 13px; padding: 3px 0; line-height: 1.4; }
  .qd-actions-summary-num { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border-radius: 50%; background: #f7eed8; border: 1.5px solid #6a7a8a; font-weight: 700; font-size: 11px; color: #2a3a4a; flex-shrink: 0; line-height: 1; }
  .qd-actions-summary-title { color: #2a3a4a; font-weight: 600; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
  .qd-actions-summary-next3 .qd-action-status { font-size: 10px; padding: 1px 6px; }
  .qd-actions-summary-next3 li.qd-action-status-done .qd-actions-summary-title { text-decoration: line-through; opacity: 0.6; }
  /* Empty-state placeholder — shown when one side has actions, the other doesn't. */
  .qd-actions.qd-actions-empty { padding: 14px 18px; opacity: 0.85; border-style: dashed; border-width: 2px; }
  .qd-actions-empty .qd-actions-summary-head { padding-bottom: 8px; border-bottom: 1px dashed rgba(42,58,74,0.2); margin-bottom: 8px; }
  .qd-actions-empty-badge { font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 11px; background: #f7eed8; color: #6a7a8a; border: 1.5px dashed #6a7a8a; letter-spacing: 0.5px; text-transform: uppercase; }
  .qd-actions-empty-hint { margin: 0; font-size: 13px; line-height: 1.5; color: #6a7a8a; }
  .qd-actions-empty-hint code { background: #f7eed8; padding: 1px 5px; border-radius: 4px; font-size: 12px; color: #2a3a4a; }
  .qd-actions-empty-hint a { color: #ff6a3a; font-weight: 600; }
  /* Hide-done toggle (lives inside Claude Actions header) */
  .qd-actions-hide-done { padding: 4px 10px; background: #fffdf2; border: 2px solid #2a3a4a; border-radius: 10px; font-family: inherit; font-weight: 700; font-size: 12px; color: #2a3a4a; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; letter-spacing: 0.5px; transition: transform 0.1s ease; }
  .qd-actions-hide-done:hover { transform: translateY(-1px); }
  .qd-actions-hide-done.on { background: #5e9a4a; color: #fff; border-color: #2a5a1a; }
  .qd-actions-hide-done-mark { display: inline-block; width: 14px; height: 14px; border: 2px solid currentColor; border-radius: 3px; text-align: center; font-weight: 800; line-height: 10px; font-size: 11px; }
  .qd-actions-hide-done.on .qd-actions-hide-done-mark { background: #fff; color: #2a5a1a; }
  .qd-actions-hide-done:not(.on) .qd-actions-hide-done-mark { color: transparent; }
  /* When the toggle is on, hide [done] action rows in the expanded list AND the summary peek */
  .qd-actions.qd-actions-hide-done .qd-actions-list .qd-action-status-done { display: none; }
  .qd-actions.qd-actions-hide-done .qd-actions-summary-next3 li.qd-action-status-done { display: none; }
</style>
</head>
<body>
{{{active_picker_html}}}
{{{quest_blocks_html}}}
<script>
(function() {
  var pid = (location.pathname.split('/').filter(Boolean)[0]) || 'default';

  // ---- ?q=<id> dispatcher: which quest block is visible ----
  var defaultQid = {{{default_quest_json}}};
  var params = new URLSearchParams(location.search);
  var requested = params.get('q') || defaultQid;
  function activate(qid) {
    var blocks = document.querySelectorAll('.qd-quest-block');
    var found = null;
    blocks.forEach(function(b) {
      if (b.getAttribute('data-quest-id') === qid) {
        b.classList.add('qd-active'); found = b;
      } else {
        b.classList.remove('qd-active');
      }
    });
    if (!found && blocks.length) {
      blocks[0].classList.add('qd-active'); found = blocks[0];
    }
    if (found) {
      var name = found.getAttribute('data-quest-name') || '';
      var n = found.getAttribute('data-quest-n') || '';
      if (name) document.title = (document.title.split(' — ')[0]) + ' — Quest ' + n + ': ' + name;
    }
    // Update active-picker highlight
    document.querySelectorAll('.qd-active-picker a').forEach(function(a) {
      a.classList.toggle('qd-active-picker-current', a.getAttribute('data-qid') === qid);
    });
  }
  activate(requested);

  // ---- Hide-done-deeds toggle (per-project) ----
  var FILTER_KEY = 'qd-filter-' + pid;
  function loadFilter() {
    try { return JSON.parse(localStorage.getItem(FILTER_KEY)) || {}; } catch (e) { return {}; }
  }
  function saveFilter(s) {
    try { localStorage.setItem(FILTER_KEY, JSON.stringify(s)); } catch (e) {}
  }
  var fState = loadFilter();
  function applyFilter() {
    document.body.classList.toggle('hide-done-deeds', !!fState.hideDoneDeeds);
    document.querySelectorAll('.qd-deeds-toggle').forEach(function(btn) {
      btn.classList.toggle('on', !!fState.hideDoneDeeds);
      btn.setAttribute('aria-pressed', fState.hideDoneDeeds ? 'true' : 'false');
    });
  }
  document.querySelectorAll('.qd-deeds-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      fState.hideDoneDeeds = !fState.hideDoneDeeds;
      saveFilter(fState); applyFilter();
    });
  });
  applyFilter();

  // ---- Per-section hide-done toggle (Claude / User Actions) ----
  // Key shape: qd-hide-done-<pid>-<quest-id>-<scope>  → "1" | "0"
  function hideDoneKey(qid, scope) {
    return 'qd-hide-done-' + pid + '-' + qid + '-' + scope;
  }
  document.querySelectorAll('.qd-actions-hide-done').forEach(function(btn) {
    var scope = btn.getAttribute('data-qd-hide-done') || 'cc';
    var section = btn.closest('.qd-actions');
    var qBlock = btn.closest('.qd-quest-block');
    var qid = qBlock ? qBlock.getAttribute('data-quest-id') : 'default';
    var k = hideDoneKey(qid, scope);
    var on = false;
    try { on = localStorage.getItem(k) === '1'; } catch (e) {}
    function apply() {
      section.classList.toggle('qd-actions-hide-done', on);
      btn.classList.toggle('on', on);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
    }
    apply();
    // Don't let the click propagate to <summary> (which would toggle the details).
    btn.addEventListener('click', function(e) {
      e.preventDefault(); e.stopPropagation();
      on = !on;
      try { localStorage.setItem(k, on ? '1' : '0'); } catch (err) {}
      apply();
    });
  });

  // ---- Per-section collapse persistence (Deeds + To-Do) ----
  // Key shape: qd-collapse-<pid>-<quest-id>-<section>  → "open" | "closed"
  function collapseKey(qid, section) {
    return 'qd-collapse-' + pid + '-' + qid + '-' + section;
  }
  document.querySelectorAll('details[data-qd-collapse]').forEach(function(det) {
    var section = det.getAttribute('data-qd-collapse');
    var qBlock = det.closest('.qd-quest-block');
    var qid = qBlock ? qBlock.getAttribute('data-quest-id') : 'default';
    var k = collapseKey(qid, section);
    var stored = null;
    try { stored = localStorage.getItem(k); } catch (e) {}
    // Default = closed (collapsed by default per spec); user can open & we remember.
    if (stored === 'open') det.open = true;
    else if (stored === 'closed') det.open = false;
    det.addEventListener('toggle', function() {
      try { localStorage.setItem(k, det.open ? 'open' : 'closed'); } catch (e) {}
    });
  });
})();
</script>
</body>
</html>
