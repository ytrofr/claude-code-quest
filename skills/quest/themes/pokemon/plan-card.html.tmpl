{{{active_picker_html}}}
{{{quest_blocks_html}}}
<script>
(function() {
  var pid = (location.pathname.split('/').filter(Boolean)[0]) || 'default';

  // ---- ?q=<id> dispatcher: which quest block is visible ----
  var defaultQid = {{{default_quest_json}}};
  var params = new URLSearchParams(location.search);
  var requested = params.get('q') || defaultQid;
  function activate(qid) {
    var blocks = document.querySelectorAll('.qd-quest-block');
    var found = null;
    blocks.forEach(function(b) {
      if (b.getAttribute('data-quest-id') === qid) {
        b.classList.add('qd-active'); found = b;
      } else {
        b.classList.remove('qd-active');
      }
    });
    if (!found && blocks.length) {
      blocks[0].classList.add('qd-active'); found = blocks[0];
    }
    if (found) {
      var name = found.getAttribute('data-quest-name') || '';
      var n = found.getAttribute('data-quest-n') || '';
      if (name) document.title = (document.title.split(' — ')[0]) + ' — Quest ' + n + ': ' + name;
    }
    // Update active-picker highlight
    document.querySelectorAll('.qd-active-picker a').forEach(function(a) {
      a.classList.toggle('qd-active-picker-current', a.getAttribute('data-qid') === qid);
    });
  }
  activate(requested);

  // ---- Hide-done-deeds toggle (per-project) ----
  var FILTER_KEY = 'qd-filter-' + pid;
  function loadFilter() {
    try { return JSON.parse(localStorage.getItem(FILTER_KEY)) || {}; } catch (e) { return {}; }
  }
  function saveFilter(s) {
    try { localStorage.setItem(FILTER_KEY, JSON.stringify(s)); } catch (e) {}
  }
  var fState = loadFilter();
  function applyFilter() {
    document.body.classList.toggle('hide-done-deeds', !!fState.hideDoneDeeds);
    document.querySelectorAll('.qd-deeds-toggle').forEach(function(btn) {
      btn.classList.toggle('on', !!fState.hideDoneDeeds);
      btn.setAttribute('aria-pressed', fState.hideDoneDeeds ? 'true' : 'false');
    });
  }
  document.querySelectorAll('.qd-deeds-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      fState.hideDoneDeeds = !fState.hideDoneDeeds;
      saveFilter(fState); applyFilter();
    });
  });
  applyFilter();

  // ---- Per-section hide-done toggle (Claude / User Actions) ----
  // Key shape: qd-hide-done-<pid>-<quest-id>-<scope>  → "1" | "0"
  function hideDoneKey(qid, scope) {
    return 'qd-hide-done-' + pid + '-' + qid + '-' + scope;
  }
  document.querySelectorAll('.qd-actions-hide-done').forEach(function(btn) {
    var scope = btn.getAttribute('data-qd-hide-done') || 'cc';
    var section = btn.closest('.qd-actions');
    var qBlock = btn.closest('.qd-quest-block');
    var qid = qBlock ? qBlock.getAttribute('data-quest-id') : 'default';
    var k = hideDoneKey(qid, scope);
    var on = false;
    try { on = localStorage.getItem(k) === '1'; } catch (e) {}
    function apply() {
      section.classList.toggle('qd-actions-hide-done', on);
      btn.classList.toggle('on', on);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
    }
    apply();
    // Don't let the click propagate to <summary> (which would toggle the details).
    btn.addEventListener('click', function(e) {
      e.preventDefault(); e.stopPropagation();
      on = !on;
      try { localStorage.setItem(k, on ? '1' : '0'); } catch (err) {}
      apply();
    });
  });

  // ---- Per-section collapse persistence (Deeds + To-Do) ----
  // Key shape: qd-collapse-<pid>-<quest-id>-<section>  → "open" | "closed"
  function collapseKey(qid, section) {
    return 'qd-collapse-' + pid + '-' + qid + '-' + section;
  }
  document.querySelectorAll('details[data-qd-collapse]').forEach(function(det) {
    var section = det.getAttribute('data-qd-collapse');
    var qBlock = det.closest('.qd-quest-block');
    var qid = qBlock ? qBlock.getAttribute('data-quest-id') : 'default';
    var k = collapseKey(qid, section);
    var stored = null;
    try { stored = localStorage.getItem(k); } catch (e) {}
    // Default = closed (collapsed by default per spec); user can open & we remember.
    if (stored === 'open') det.open = true;
    else if (stored === 'closed') det.open = false;
    det.addEventListener('toggle', function() {
      try { localStorage.setItem(k, det.open ? 'open' : 'closed'); } catch (e) {}
    });
  });
})();

/* Copy briefing button — reads the hidden <pre.qd-briefing-raw> inside the
   same quest article and copies its text to the clipboard. */
(function() {
  document.querySelectorAll('[data-qd="copy-briefing"]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var article = btn.closest('article.qd-quest-block') || document;
      var pre = article.querySelector('.qd-briefing-raw');
      if (!pre) return;
      var text = pre.textContent || '';
      var label = btn.querySelector('.qd-copy-label');
      var done = function() {
        if (label) {
          var orig = label.textContent;
          label.textContent = 'Copied!';
          setTimeout(function() { label.textContent = orig; }, 1500);
        }
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done, function() {
          // Fallback: select text in a temp textarea
          var ta = document.createElement('textarea');
          ta.value = text; document.body.appendChild(ta); ta.select();
          try { document.execCommand('copy'); done(); }
          catch (e) { alert('Copy unavailable. Text:\n\n' + text); }
          document.body.removeChild(ta);
        });
      } else {
        alert('Copy unavailable. Text:\n\n' + text);
      }
    });
  });
})();

/* ============================================================
   Tag chips: add/remove tags from THIS quest via /api/tags/*.
   Mirrors quest-log.html.tmpl chip JS but targets the per-block
   `<article class="qd-quest-block" data-project-id="..." data-quest-id="..."
   data-quest-tags="...">` wrapper. Only one block is `qd-active` at a time;
   the JS still wires every block (cheap, future-proof when the picker switches).
============================================================ */
(function() {
  function esc(s) {
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }
  function chipClass(t) {
    if (t.indexOf('session:') === 0)  return 'qd-chip session';
    if (t.indexOf('priority:') === 0) return 'qd-chip priority';
    return 'qd-chip';
  }
  function chipLabel(t) {
    return t.indexOf('session:') === 0 ? t.slice(8) : t;
  }
  function showToast(msg, isErr) {
    var toast = document.getElementById('qd-toast');
    if (!toast) {
      toast = document.createElement('div');
      toast.id = 'qd-toast';
      toast.className = 'qd-toast';
      document.body.appendChild(toast);
    }
    toast.textContent = msg;
    toast.className = 'qd-toast show' + (isErr ? ' error' : '');
    clearTimeout(toast._t);
    toast._t = setTimeout(function() { toast.className = 'qd-toast' + (isErr ? ' error' : ''); }, 2200);
  }
  function apiCall(path, body) {
    return fetch(path, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    }).then(function(r) { return r.json(); })
      .catch(function() { return { ok: false, msg: 'Network error' }; });
  }

  function renderChips(article) {
    var slot = article.querySelector('[data-qd-chips]');
    if (!slot) return;
    var raw = (article.dataset.questTags || '').trim();
    var tags = raw ? raw.split(',').map(function(t) { return t.trim(); }).filter(Boolean) : [];
    var proj = article.dataset.projectId || '';
    var html = tags.map(function(t) {
      var cls = chipClass(t);
      // Chip body links to quest-log filtered by this tag (nice side benefit
      // — keeps tag-as-filter affordance from the Quest Log view).
      var href = 'quest-log.html?q=' + encodeURIComponent(t);
      return '<a class="' + cls + '" href="' + esc(href) + '" data-tag="' + esc(t) + '" title="Click to view Quest Log filtered by this tag; ✕ to remove">'
           +   esc(chipLabel(t))
           +   '<span class="qd-chip-x" data-remove="' + esc(t) + '" title="Remove tag">×</span>'
           + '</a>';
    }).join('');
    html += '<button type="button" class="qd-chip-add" data-add-tag title="Add a freeform tag (priority:p0, audit, area/auth, etc.)">+ tag</button>';
    html += '<button type="button" class="qd-chip-add qd-chip-add-session" data-bind-session title="Bind to a chat conversation — auto-prefixed session:">💬 + session</button>';
    slot.innerHTML = html;
  }

  // Initial render for every article (visible + hidden)
  document.querySelectorAll('article.qd-quest-block[data-quest-id]').forEach(renderChips);

  document.addEventListener('click', function(e) {
    var article = e.target.closest('article.qd-quest-block[data-quest-id]');
    if (!article) return;
    var proj = article.dataset.projectId || '';
    var qid = article.dataset.questId || '';

    // Remove tag (× button)
    var removeBtn = e.target.closest('[data-remove]');
    if (removeBtn) {
      e.preventDefault(); e.stopPropagation();
      var removedTag = removeBtn.dataset.remove;
      apiCall('/api/tags/remove', { project: proj, id: qid, tag: removedTag }).then(function(res) {
        if (res.ok) {
          article.dataset.questTags = (res.tags || []).join(',');
          renderChips(article);
          if (removedTag.indexOf('session:') === 0) {
            showToast('Removed: ' + removedTag + ' — refreshing…');
            setTimeout(function() { location.reload(); }, 700);
          } else {
            showToast('Removed: ' + removedTag);
          }
        } else {
          showToast(res.msg || 'Failed', true);
        }
      });
      return;
    }

    // Bind to a conversation (+ session button) — auto-prefixes session:
    var bindBtn = e.target.closest('[data-bind-session]');
    if (bindBtn) {
      e.preventDefault(); e.stopPropagation();
      var sInput = document.createElement('input');
      sInput.type = 'text';
      sInput.className = 'qd-chip-input';
      sInput.placeholder = 'conversation name…';
      sInput.maxLength = 64;
      bindBtn.replaceWith(sInput);
      sInput.focus();
      var done = false;
      var sCommit = function() {
        if (done) return; done = true;
        var val = (sInput.value || '').trim();
        if (!val) { renderChips(article); return; }
        apiCall('/api/tags/bind', { project: proj, id: qid, name: val }).then(function(res) {
          if (res.ok) {
            article.dataset.questTags = (res.tags || []).join(',');
            renderChips(article);
            showToast('Bound to: ' + val + ' — refreshing…');
            setTimeout(function() { location.reload(); }, 700);
          } else {
            showToast(res.msg || 'Failed', true);
            renderChips(article);
          }
        });
      };
      sInput.addEventListener('keydown', function(ev) {
        if (ev.key === 'Enter') { ev.preventDefault(); sCommit(); }
        else if (ev.key === 'Escape') { done = true; renderChips(article); }
      });
      sInput.addEventListener('blur', sCommit);
      return;
    }

    // Add tag (+ tag button)
    var addBtn = e.target.closest('[data-add-tag]');
    if (addBtn) {
      e.preventDefault(); e.stopPropagation();
      var input = document.createElement('input');
      input.type = 'text';
      input.className = 'qd-chip-input';
      input.placeholder = 'tag,tag2…';
      input.maxLength = 200;
      addBtn.replaceWith(input);
      input.focus();
      var done = false;
      var commit = function() {
        if (done) return; done = true;
        var val = (input.value || '').trim();
        if (!val) { renderChips(article); return; }
        apiCall('/api/tags/add', { project: proj, id: qid, tag: val }).then(function(res) {
          if (res.ok) {
            article.dataset.questTags = (res.tags || []).join(',');
            renderChips(article);
            if (val.indexOf('session:') !== -1) {
              showToast('Tagged: ' + val + ' — refreshing…');
              setTimeout(function() { location.reload(); }, 700);
            } else {
              showToast('Tagged: ' + val);
            }
          } else {
            showToast(res.msg || 'Failed', true);
            renderChips(article);
          }
        });
      };
      input.addEventListener('keydown', function(ev) {
        if (ev.key === 'Enter') { ev.preventDefault(); commit(); }
        else if (ev.key === 'Escape') { done = true; renderChips(article); }
      });
      input.addEventListener('blur', commit);
      return;
    }
  });
})();

// ============ Quest title rename (in plan-card) ============
(function() {
  function getArticleAndIds(buttonEl) {
    var article = buttonEl.closest('article.qd-quest-block');
    if (!article) return null;
    return {
      article: article,
      project: article.dataset.projectId || '',
      qid: article.dataset.questId || '',
      titleEl: article.querySelector('.qd-quest-title-display'),
      editEl: article.querySelector('.qd-rename-edit'),
      btnEl: article.querySelector('.qd-rename-btn'),
      inputEl: article.querySelector('.qd-rename-input'),
      errEl: article.querySelector('.qd-rename-err'),
    };
  }
  window.qdStartRename = function(btn) {
    var ctx = getArticleAndIds(btn);
    if (!ctx) return;
    ctx.inputEl.value = ctx.titleEl.textContent.trim();
    ctx.editEl.style.display = 'block';
    ctx.btnEl.style.display = 'none';
    ctx.titleEl.style.display = 'none';
    ctx.errEl.style.display = 'none';
    ctx.inputEl.focus();
    ctx.inputEl.select();
  };
  window.qdCancelRename = function(btn) {
    var ctx = getArticleAndIds(btn);
    if (!ctx) return;
    ctx.editEl.style.display = 'none';
    ctx.btnEl.style.display = '';
    ctx.titleEl.style.display = '';
    ctx.errEl.style.display = 'none';
  };
  window.qdCommitRename = function(btn) {
    var ctx = getArticleAndIds(btn);
    if (!ctx) return;
    var newName = (ctx.inputEl.value || '').trim();
    if (!newName) {
      ctx.errEl.textContent = 'Name cannot be empty';
      ctx.errEl.style.display = 'block';
      return;
    }
    if (!ctx.project || !ctx.qid) {
      ctx.errEl.textContent = 'Could not detect project/quest from article';
      ctx.errEl.style.display = 'block';
      return;
    }
    btn.disabled = true;
    fetch('/api/quest/rename', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ project: ctx.project, id: ctx.qid, name: newName }),
    }).then(function(r) { return r.json().then(function(j) { return { ok: r.ok, j: j }; }); })
      .then(function(res) {
        if (!res.ok || !res.j.ok) throw new Error(res.j.error || res.j.msg || 'HTTP error');
        ctx.titleEl.textContent = newName;
        ctx.errEl.style.display = 'none';
        ctx.editEl.style.display = 'none';
        ctx.btnEl.style.display = '';
        ctx.titleEl.style.display = '';
        setTimeout(function() { window.location.reload(); }, 600);
      })
      .catch(function(e) {
        btn.disabled = false;
        ctx.errEl.textContent = 'Rename failed: ' + e.message;
        ctx.errEl.style.display = 'block';
      });
  };
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && e.target && e.target.classList && e.target.classList.contains('qd-rename-input')) {
      e.preventDefault();
      var btn = e.target.closest('.qd-rename-edit').querySelector('button');
      if (btn) qdCommitRename(btn);
    } else if (e.key === 'Escape' && e.target && e.target.classList && e.target.classList.contains('qd-rename-input')) {
      var cancel = e.target.closest('.qd-rename-edit').querySelectorAll('button')[1];
      if (cancel) qdCancelRename(cancel);
    }
  });
})();
</script>
</body>
