<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{name}} — Route Map</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; }
  body { margin: 0; min-height: 100vh; font-family: 'Fredoka', system-ui, sans-serif; background: #5db4d8; padding: 18px; }
  .frame { max-width: 1280px; margin: 0 auto; background: #fffdf2; border: 4px solid #2a3a4a; border-radius: 16px; overflow: hidden; box-shadow: 0 12px 30px rgba(20,40,60,0.4); }
  .head { padding: 14px 22px; background: linear-gradient(180deg, #fff 0%, #f7eed8 100%); border-bottom: 4px solid #2a3a4a; display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; }
  .title { display: flex; align-items: center; gap: 12px; }
  .badge { width: 50px; height: 50px; background: #ffd24a; border: 3px solid #2a3a4a; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 22px; color: #2a3a4a; box-shadow: 0 3px 0 #c9a020; line-height: 1; }
  h1 { margin: 0; font-weight: 700; font-size: 26.4px; color: #2a3a4a; line-height: 1.1; }
  .sub { font-weight: 500; font-size: 14.3px; color: #6a7a8a; margin-top: 2px; }
  .nav { display: flex; gap: 6px; margin: 0 8px; align-items: center; }
  .nav a { padding: 8px 14px; background: #fffdf2; border: 2.5px solid #2a3a4a; border-radius: 10px; font-weight: 700; font-size: 13.2px; color: #2a3a4a; text-decoration: none; letter-spacing: 1px; text-transform: uppercase; }
  .nav a.active { background: #2a3a4a; color: #ffd24a; }
  .qd-back-link { padding: 6px 12px; background: #ffd24a; border: 2.5px solid #2a3a4a; border-radius: 10px; color: #2a3a4a; text-decoration: none; font-weight: 700; font-size: 12.1px; letter-spacing: 1px; text-transform: uppercase; box-shadow: 0 3px 0 #c9a020; }
  .qd-back-link:hover { transform: translateY(1px); box-shadow: 0 2px 0 #c9a020; }
  .xp-block { display: flex; align-items: center; gap: 12px; }
  .xp-label { font-weight: 700; font-size: 13.2px; color: #2a3a4a; text-transform: uppercase; letter-spacing: 1px; }
  .xp-bar { width: 200px; height: 18px; background: #f0e4cc; border: 3px solid #2a3a4a; border-radius: 10px; overflow: hidden; position: relative; }
  .xp-fill { height: 100%; background: linear-gradient(180deg, #ffd24a 0%, #d4a020 100%); border-right: 2px solid #2a3a4a; }
  .xp-text { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12.1px; color: #2a3a4a; }
  .map-wrap { position: relative; }
  .map { width: 100%; display: block; background: #8fc97a; }
  .legend { display: flex; gap: 14px; padding: 12px 22px; font-weight: 600; font-size: 13.2px; color: #4a5a6a; background: #fffdf2; border-top: 2px solid #2a3a4a; }
  .legend span { display: inline-flex; align-items: center; gap: 6px; }
  .legend .dot { width: 12px; height: 12px; border-radius: 50%; border: 2px solid #2a3a4a; }
  .footer { padding: 14px 22px; background: #fffdf2; border-top: 4px solid #2a3a4a; display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; }
  .now { display: flex; align-items: center; gap: 12px; }
  .now-tag { padding: 5px 12px; background: #ff6a3a; color: #fff; font-weight: 700; font-size: 12.1px; letter-spacing: 1.5px; text-transform: uppercase; border-radius: 4px; border: 2px solid #2a3a4a; box-shadow: 0 2px 0 #2a3a4a; }
  .now-name { font-weight: 700; font-size: 19.8px; color: #2a3a4a; }
  .progress-pill { display: flex; align-items: center; gap: 10px; }
  .progress-pill .bar { width: 160px; height: 12px; background: #f0e4cc; border: 2px solid #2a3a4a; border-radius: 8px; overflow: hidden; }
  .progress-pill .fill { height: 100%; background: linear-gradient(180deg, #ff8a4a 0%, #ff5a20 100%); }
  .progress-pill .pct { font-weight: 700; font-size: 15.4px; color: #2a3a4a; }
  /* Quest marker status visibility */
  .qm-locked { opacity: 0.62; }
  .badge-done, .badge-current, .trainer { display: none; }
  .qm-done .badge-done { display: block; }
  .qm-current .badge-current { display: block; }
  .qm-current .trainer { display: block; }
  /* Animations */
  .bobby { animation: bob 1.4s ease-in-out infinite; transform-origin: bottom center; transform-box: fill-box; }
  @keyframes bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-3px); } }
  .twinkle { animation: tw 1.6s ease-in-out infinite; transform-origin: center; transform-box: fill-box; }
  @keyframes tw { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.08); opacity: 0.85; } }
  .lbl-region { font-family: 'Fredoka'; font-weight: 700; font-size: 9.9px; letter-spacing: 3px; }
</style>
</head>
<body>
<div class="frame">
  <header class="head">
    <div class="title">
      <div class="badge">{{level_roman}}</div>
      <div>
        <h1>{{name}} Region</h1>
        <div class="sub">{{subtitle}} · {{counts.total}} routes</div>
      </div>
    </div>
    <nav class="nav">
      {{> _back-link}}
      <a href="route.html" class="active">MAP</a>
      <a href="quest-log.html">QUEST LOG</a>
    </nav>
    <div class="xp-block">
      <span class="xp-label">XP</span>
      <div class="xp-bar"><div class="xp-fill" style="width:{{xp_pct}}%"></div><div class="xp-text">{{xp.current}} / {{xp.max}}</div></div>
    </div>
  </header>

  <div class="map-wrap">
    <svg class="map" viewBox="0 0 1200 540" preserveAspectRatio="xMidYMid slice">
      <!-- Sky strip -->
      <rect x="0" y="0" width="1200" height="60" fill="#bbe4f5"/>
      <g fill="#fff" opacity="0.9">
        <ellipse cx="200" cy="32" rx="44" ry="14"/><ellipse cx="222" cy="26" rx="32" ry="11"/>
        <ellipse cx="780" cy="28" rx="50" ry="14"/><ellipse cx="800" cy="22" rx="38" ry="11"/>
      </g>
      <!-- Grass -->
      <rect x="0" y="60" width="1200" height="480" fill="#8fc97a"/>
      <!-- Water lake top-right -->
      <path d="M 820 60 Q 880 130 1010 110 Q 1130 95 1200 140 L 1200 60 Z" fill="#7ec0dc"/>
      <path d="M 820 60 Q 880 130 1010 110 Q 1130 95 1200 140" stroke="#4a90b0" stroke-width="3" fill="none"/>
      <g stroke="#fff" stroke-width="1.5" fill="none" opacity="0.7">
        <path d="M 940 100 q 8 -3 16 0 t 16 0"/><path d="M 1050 122 q 8 -3 16 0 t 16 0"/>
      </g>
      <!-- Mountains -->
      <g>
        <polygon points="60,200 130,80 200,200" fill="#a89380" stroke="#5a4830" stroke-width="3"/>
        <polygon points="80,200 110,140 140,200" fill="#bda594" stroke="#5a4830" stroke-width="2"/>
        <polygon points="170,200 220,110 270,200" fill="#a89380" stroke="#5a4830" stroke-width="3"/>
        <polygon points="190,200 220,150 250,200" fill="#fff" opacity="0.6"/>
      </g>
      <text x="160" y="232" text-anchor="middle" class="lbl-region" fill="#5a4830">— PEAKS —</text>
      <text x="350" y="490" text-anchor="middle" class="lbl-region" fill="#3a5828">— DEEP WOODS —</text>
      <text x="1010" y="155" text-anchor="middle" class="lbl-region" fill="#205070">— LAKE NIPHAL —</text>

      <!-- Forest -->
      <g>
        <g transform="translate(380,420)"><ellipse cx="0" cy="6" rx="20" ry="4" fill="rgba(0,0,0,0.2)"/><rect x="-3" y="-12" width="6" height="14" fill="#6a4020"/><circle cx="0" cy="-22" r="20" fill="#3a7a3a" stroke="#2a5a2a" stroke-width="2.5"/><circle cx="-7" cy="-30" r="9" fill="#4a8a4a" opacity="0.6"/></g>
        <g transform="translate(420,440)"><ellipse cx="0" cy="6" rx="18" ry="4" fill="rgba(0,0,0,0.2)"/><rect x="-3" y="-10" width="6" height="12" fill="#6a4020"/><circle cx="0" cy="-20" r="17" fill="#3a7a3a" stroke="#2a5a2a" stroke-width="2.5"/></g>
        <g transform="translate(360,460)"><ellipse cx="0" cy="6" rx="20" ry="4" fill="rgba(0,0,0,0.2)"/><rect x="-3" y="-10" width="6" height="12" fill="#6a4020"/><circle cx="0" cy="-20" r="18" fill="#3a7a3a" stroke="#2a5a2a" stroke-width="2.5"/></g>
        <g transform="translate(280,440)"><ellipse cx="0" cy="6" rx="16" ry="3" fill="rgba(0,0,0,0.2)"/><rect x="-2" y="-8" width="4" height="10" fill="#6a4020"/><circle cx="0" cy="-16" r="14" fill="#4a8a4a" stroke="#2a5a2a" stroke-width="2"/></g>
      </g>
      <g fill="#5aa050" stroke="#3a7a3a" stroke-width="2">
        <ellipse cx="600" cy="450" rx="22" ry="12"/><ellipse cx="635" cy="445" rx="14" ry="9"/>
        <ellipse cx="900" cy="440" rx="20" ry="11"/>
        <ellipse cx="150" cy="420" rx="18" ry="10"/>
      </g>

      <!-- Sandy path -->
      <path d="M 90 460 Q 200 420 280 380 Q 360 340 460 320 Q 560 305 640 290 Q 740 275 830 260 Q 920 240 980 200 Q 1040 160 1090 130" stroke="#5a4830" stroke-width="36" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M 90 460 Q 200 420 280 380 Q 360 340 460 320 Q 560 305 640 290 Q 740 275 830 260 Q 920 240 980 200 Q 1040 160 1090 130" stroke="#efd9a3" stroke-width="28" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M 1090 130 Q 1140 100 1170 70" stroke="#5a4830" stroke-width="24" fill="none" stroke-linecap="round" stroke-dasharray="14 12" opacity="0.4"/>

      <!-- ===== QUEST MARKERS (rendered from data) ===== -->
      {{#each quests}}
      <g transform="{{q.transform}}" class="qm qm-{{q.status_class}}" data-quest="{{q.id}}">
        {{{q.landmark_svg}}}

        <!-- Done check badge (CSS-toggled) -->
        <g class="badge-done">
          <circle cx="22" cy="-22" r="10" fill="#5e9a4a" stroke="#fff" stroke-width="2.5"/>
          <path d="M 18 -22 l 3 4 l 7 -7" stroke="#fff" stroke-width="2.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </g>

        <!-- Current ! badge + trainer pawn (CSS-toggled) -->
        <g class="badge-current twinkle">
          <circle cx="0" cy="-66" r="11" fill="#ffd24a" stroke="#5a1818" stroke-width="2.5"/>
          <text x="0" y="-66" text-anchor="middle" dominant-baseline="central" font-family="Fredoka" font-weight="900" font-size="14" fill="#5a1818">!</text>
        </g>
        <g class="trainer bobby" transform="translate(-58, 0)">
          <ellipse cx="0" cy="22" rx="10" ry="3" fill="rgba(0,0,0,0.3)"/>
          <circle cx="0" cy="-8" r="9" fill="#ffd9a8" stroke="#3a2010" stroke-width="2"/>
          <circle cx="-3" cy="-9" r="1.2" fill="#3a2010"/><circle cx="3" cy="-9" r="1.2" fill="#3a2010"/>
          <path d="M -10 -14 Q 0 -22 10 -14 L 10 -10 L -10 -10 Z" fill="#d63a3a" stroke="#3a2010" stroke-width="2"/>
          <rect x="-7" y="0" width="14" height="14" fill="#3a78d0" stroke="#1a3060" stroke-width="2"/>
          <rect x="-9" y="14" width="6" height="8" fill="#3a2010"/><rect x="3" y="14" width="6" height="8" fill="#3a2010"/>
        </g>

        <!-- Label -->
        <rect x="-50" y="32" width="100" height="22" fill="#fff" stroke="#2a3a4a" stroke-width="2.5" rx="5"/>
        <text x="0" y="48" text-anchor="middle" font-family="Fredoka" font-weight="700" font-size="11" fill="#2a3a4a">{{q.n}} · {{q.name}}</text>
      </g>
      {{/each}}

      <!-- Compass -->
      <g transform="translate(1140, 470)">
        <circle r="28" fill="#fff" stroke="#2a3a4a" stroke-width="3"/>
        <polygon points="0,-22 5,0 0,22 -5,0" fill="#d63a3a"/>
        <polygon points="-22,0 0,-3 22,0 0,3" fill="#2a3a4a"/>
        <text x="0" y="-32" text-anchor="middle" font-family="Fredoka" font-weight="700" font-size="10" fill="#2a3a4a">N</text>
      </g>
    </svg>
  </div>

  <div class="legend">
    <span><span class="dot" style="background:#5e9a4a"></span>visited ({{counts.done}})</span>
    <span><span class="dot" style="background:#ff6a3a"></span>now ({{counts.current}})</span>
    <span><span class="dot" style="background:#bbb"></span>sealed ({{counts.locked}})</span>
  </div>

  <footer class="footer">
    <div class="now">
      <span class="now-tag">Quest {{active.n}}</span>
      <span class="now-name">{{active.name}}</span>
    </div>
    <div class="progress-pill">
      <div class="bar"><div class="fill" style="width:{{active_progress_pct}}%"></div></div>
      <span class="pct">{{active_progress_pct}}%</span>
    </div>
  </footer>
</div>
</body>
</html>
