<!-- Partial: _actions-user
     Scope: actions_user (list), actions_user_done, actions_user_total, actions_user_next
     Mirror of _actions-claude with the user-side icon + colour theme.
     Wrapped in <details data-qd-collapse="user-actions"> — collapsed by default. -->
{{#if actions_user_empty}}
<section class="qd-actions qd-actions-user qd-actions-empty" data-qd="actions-user-empty">
  <div class="qd-actions-summary-head">
    <span class="qd-actions-icon">{{> icons/user}}</span>
    <h3 class="qd-actions-title">Your Actions</h3>
    <span class="qd-actions-empty-badge">none yet</span>
  </div>
  <p class="qd-actions-empty-hint">No user actions on this quest. To add steps you (the human) need to do, append <code>## Section 14 — Your Actions</code> to the plan file with <code>### N. Title [STATUS]</code> entries. <a href="https://github.com/ytrofr/claude-code-quest" target="_blank" rel="noopener">Docs</a></p>
</section>
{{/if}}
{{#if actions_user}}
<section class="qd-actions qd-actions-user" data-qd="actions-user">
  <details data-qd-collapse="user-actions">
    <summary class="qd-actions-summary">
      <div class="qd-actions-summary-head">
        <span class="qd-actions-summary-arrow" aria-hidden="true">▸</span>
        <span class="qd-actions-icon">{{> icons/user}}</span>
        <h3 class="qd-actions-title">Your Actions</h3>
        <span class="qd-actions-count">{{actions_user_done}} / {{actions_user_total}}</span>
      </div>
      {{#if actions_user_next3}}
      <ol class="qd-actions-summary-next3">
        {{#each actions_user_next3}}
        <li class="qd-action-status-{{q.status_class}}"><span class="qd-actions-summary-num">{{q.n}}</span><span class="qd-actions-summary-title">{{q.title}}</span>{{#if q.status}}<span class="qd-action-status qd-action-status-pill-{{q.status_class}}">{{q.status}}</span>{{/if}}</li>
        {{/each}}
      </ol>
      {{/if}}
    </summary>
    <ol class="qd-actions-list">
      {{#each actions_user}}
      <li class="qd-action qd-action-status-{{q.status_class}}">
        <span class="qd-action-num">{{q.n}}</span>
        <div class="qd-action-body">
          <p class="qd-action-head">{{q.title}}{{#if q.status}}<span class="qd-action-status qd-action-status-pill-{{q.status_class}}">{{q.status}}</span>{{/if}}</p>
          {{{q.body_html}}}
        </div>
      </li>
      {{/each}}
    </ol>
  </details>
</section>
{{/if}}
