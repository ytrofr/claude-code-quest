<!-- Partial: _user-tasks
     Scope keys used: tasks_user (list), tasks_user_done (int), tasks_user_total (int),
                      tasks_user_next (str — title of first not-done task)
     Renders only when `tasks_user` is non-empty.
     Each task object: { title, done, done_class, done_mark, problem?, solution?, has_brief? }
     Wrapped in <details data-qd-collapse="user"> — collapsed by default; JS persists.
     Summary shows "Next: <first-undone-title>" preview when collapsed. -->
{{#if tasks_user}}
<section class="qd-user-tasks qd-tasks" data-qd="user-tasks">
  <details data-qd-collapse="user">
    <summary class="qd-tasks-summary">
      <span class="qd-tasks-summary-arrow" aria-hidden="true">▸</span>
      <h3 class="qd-tasks-title">To-Do (You)</h3>
      <span class="qd-tasks-count">{{tasks_user_done}} / {{tasks_user_total}}</span>
      {{#if tasks_user_next}}<span class="qd-tasks-summary-preview">Next: {{tasks_user_next}}</span>{{/if}}
    </summary>
    <ul class="qd-tasks-list">
      {{#each tasks_user}}
      <li class="qd-task qd-task-{{q.done_class}}">
        {{#if q.has_brief}}
        <details class="qd-task-details">
          <summary class="qd-task-summary">
            <span class="qd-task-mark" aria-hidden="true">{{q.done_mark}}</span>
            <span class="qd-task-title">{{q.title}}</span>
            <span class="qd-task-arrow" aria-hidden="true">▸</span>
          </summary>
          <div class="qd-task-brief">
            {{#if q.problem}}<p class="qd-brief-line"><strong>Problem:</strong> {{q.problem}}</p>{{/if}}
            {{#if q.solution}}<p class="qd-brief-line qd-brief-arrow"><strong>Solution:</strong> {{q.solution}}</p>{{/if}}
            {{#if q.brief}}<p class="qd-brief-line">{{q.brief}}</p>{{/if}}
          </div>
        </details>
        {{/if}}
        {{#if q.no_brief}}
        <span class="qd-task-mark" aria-hidden="true">{{q.done_mark}}</span>
        <span class="qd-task-title">{{q.title}}</span>
        {{/if}}
      </li>
      {{/each}}
    </ul>
  </details>
</section>
{{/if}}
