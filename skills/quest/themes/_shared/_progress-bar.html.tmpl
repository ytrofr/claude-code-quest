<!-- Partial: _progress-bar
     Scope keys used: progress_pct (int 0-100)
     Inline progress visualization. Themes can fully restyle via .qd-progress class. -->
<div class="qd-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{progress_pct}}">
  <div class="qd-progress-fill" style="width: {{progress_pct}}%"></div>
  <span class="qd-progress-label">{{progress_pct}}%</span>
</div>
