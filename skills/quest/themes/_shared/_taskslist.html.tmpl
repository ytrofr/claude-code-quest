<!-- Partial: _taskslist
     Scope keys used: tasks (list), tasks_done (int), tasks_total (int)
     Renders only when `tasks` is non-empty.
     Each task object: { title, done, done_class, done_mark, problem?, solution?, has_brief? }
     If has_brief, the row becomes a clickable <details> with a problem→solution expansion.
     The "Hide Done" toggle in the header sets body.hide-done-deeds; CSS in each
     theme's plan-card.html.tmpl hides .qd-task-done rows when that class is set.
     State persisted via the per-project qd-filter-<pid> localStorage key. -->
{{#if tasks}}
<section class="qd-tasks" data-qd="tasks">
  <header class="qd-tasks-head">
    <h3 class="qd-tasks-title">Deeds</h3>
    <span class="qd-tasks-count">{{tasks_done}} / {{tasks_total}}</span>
    <button class="qd-deeds-toggle" type="button" data-toggle="hide-done-deeds" aria-pressed="false" title="Hide completed deeds">
      <span class="qd-toggle-mark" aria-hidden="true">○</span>
      <span class="qd-toggle-label">Hide done</span>
    </button>
  </header>
  <ul class="qd-tasks-list">
    {{#each tasks}}
    <li class="qd-task qd-task-{{q.done_class}}">
      {{#if q.has_brief}}
      <details class="qd-task-details">
        <summary class="qd-task-summary">
          <span class="qd-task-mark" aria-hidden="true">{{q.done_mark}}</span>
          <span class="qd-task-title">{{q.title}}</span>
          <span class="qd-task-arrow" aria-hidden="true">▸</span>
        </summary>
        <div class="qd-task-brief">
          {{#if q.problem}}<p class="qd-brief-line"><strong>Problem:</strong> {{q.problem}}</p>{{/if}}
          {{#if q.solution}}<p class="qd-brief-line qd-brief-arrow"><strong>Solution:</strong> {{q.solution}}</p>{{/if}}
          {{#if q.brief}}<p class="qd-brief-line">{{q.brief}}</p>{{/if}}
        </div>
      </details>
      {{/if}}
      {{#if q.no_brief}}
      <span class="qd-task-mark" aria-hidden="true">{{q.done_mark}}</span>
      <span class="qd-task-title">{{q.title}}</span>
      {{/if}}
    </li>
    {{/each}}
  </ul>
</section>
{{/if}}
