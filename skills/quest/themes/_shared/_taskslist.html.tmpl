<!-- Partial: _taskslist
     Scope keys used: tasks (list), tasks_done (int), tasks_total (int)
     Renders only when `tasks` is non-empty.
     Each task object: { title, done, done_class, done_mark } (precomputed). -->
{{#if tasks}}
<section class="qd-tasks" data-qd="tasks">
  <header class="qd-tasks-head">
    <h3 class="qd-tasks-title">Deeds</h3>
    <span class="qd-tasks-count">{{tasks_done}} / {{tasks_total}}</span>
  </header>
  <ul class="qd-tasks-list">
    {{#each tasks}}
    <li class="qd-task qd-task-{{q.done_class}}">
      <span class="qd-task-mark" aria-hidden="true">{{q.done_mark}}</span>
      <span class="qd-task-title">{{q.title}}</span>
    </li>
    {{/each}}
  </ul>
</section>
{{/if}}
